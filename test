    else if (mods.includes('startswith')) op = 'startswith';
    else if (mods.includes('endswith'))   op = 'endswith';
    else if (mods.includes('re'))    op = 're';
    else if (mods.includes('gt'))    op = '>';
    else if (mods.includes('gte'))   op = '>=';
