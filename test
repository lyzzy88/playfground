function renderTranslate() {
  const out = $('translate-out');
  let graph;
  try { graph = parseRuleGraph(ruleEl.value); }
  catch (err) {
    out.innerHTML = '<div class="empty"><div class="msg">parse error</div><div class="hint" style="color:var(--red)">' + escapeHtml(err.message) + '</div></div>';
    return;
  }
  const primary = graph.docs[graph.docs.length - 1];
  const isCorr = !!primary.correlation;
  const title = primary.title || '(untitled)';

  let html = `
    <div class="translate-head">
      <div>▸ <b>${escapeHtml(title)}</b> ${isCorr ? '<span class="corr-chip">' + escapeHtml(primary.correlation.type||'corr') + '</span>' : ''}</div>
      <div class="meta">
        ${graph.detections.length} detection rule${graph.detections.length!==1?'s':''} · ${graph.correlations.length} correlation${graph.correlations.length!==1?'s':''}
      </div>
    </div>
  `;

  for (const b of BACKENDS) {
    let query, err;
    try {
      if (isCorr) query = b.corr(primary, graph);
      else query = b.det(primary);
    } catch (e) { err = e.message; }

    html += `
      <div class="backend-card">
        <div class="backend-head">
          <div class="backend-name"><span class="sigil">▸</span>${escapeHtml(b.name)}<span class="fmt">· ${escapeHtml(b.fmt)}</span></div>
          <button class="backend-copy" data-backend="${b.id}">COPY</button>
        </div>
        <pre class="backend-query ${err?'error':''}" id="q-${b.id}">${escapeHtml(err || query || '(empty)')}</pre>
        <div class="backend-notes"><b>NOTE</b> · ${escapeHtml(b.note)}</div>
      </div>`;
  }

  out.innerHTML = html;
  // wire copy buttons
  document.querySelectorAll('.backend-copy').forEach(btn => {
    btn.onclick = () => {
      const id = btn.dataset.backend;
      const q = document.getElementById('q-' + id).textContent;
      navigator.clipboard.writeText(q).then(() => {
        const orig = btn.textContent;
        btn.textContent = '✓ COPIED';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1200);
      });
    };
  });
}

// keyboard
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); $('execute').click(); }
  if ((e.ctrlKey || e.metaKey) && e.key === 't') { e.preventDefault(); document.querySelector('.tab[data-tab="translate"]').click(); }
});

</script>
</body>
