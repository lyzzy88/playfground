  // Fallback: hidden <input webkitdirectory>
  const input = document.createElement('input');
  input.type = 'file';
  input.webkitdirectory = true;
  input.multiple = true;
  input.onchange = async () => {
    const files = [...input.files].map(f => ({
      path: f.webkitRelativePath || f.name,
      file: f,
    })).filter(x => libIsTextFile(x.path));
    if (!files.length) return;
    const root = files[0].path.split('/')[0] || 'folder';
    await libIndexCollectedFiles(files, root);
  };
  input.click();
};

/* Refresh button: re-read all files from the persisted directory handle.
   Only works in browsers that support File System Access API. */
async function libRefresh() {
  if (!LIB.fsHandle) {
    renderError(new Error('Refresh requires the File System Access API (Chrome/Edge). Use FOLDER to re-pick the directory in this browser.'));
    return;
  }
  try {
    // Request permission - may show a prompt if not already granted
    const perm = await LIB.fsHandle.queryPermission({ mode: 'read' });
    if (perm !== 'granted') {
      const req = await LIB.fsHandle.requestPermission({ mode: 'read' });
      if (req !== 'granted') {
        renderError(new Error('Permission to read the folder was denied.'));
        return;
      }
    }
    const files = [];
    await libCollectFromHandle(LIB.fsHandle, '', files);
    await libIndexCollectedFiles(files, LIB.fsHandle.name);
  } catch (e) {
    if (e.name === 'NotFoundError') {
      renderError(new Error('The original folder is no longer accessible. Please use FOLDER to pick it again.'));
    } else {
      renderError(new Error('Refresh failed: ' + (e.message || e.name)));
    }
  }
}

async function libCollectFromHandle(dirHandle, prefix, out) {
  if (out.length >= LIB_MAX_TOTAL_FILES) return;
  for await (const [name, handle] of dirHandle.entries()) {
    if (out.length >= LIB_MAX_TOTAL_FILES) return;
    if (handle.kind === 'file') {
      if (!libIsTextFile(name)) continue;
      const file = await handle.getFile();
      out.push({ path: prefix + name, file, handle });
    } else if (handle.kind === 'directory') {
      await libCollectFromHandle(handle, prefix + name + '/', out);
    }
  }
}

/* Process collected files (paths + File objects), filter by size, build LIB.files */
async function libIndexCollectedFiles(rawFiles, rootName) {
  LIB.rootName = rootName;
  LIB.files = [];
  let skippedSize = 0;
  for (const { path, file } of rawFiles) {
    if (file.size > LIB_MAX_FILE_BYTES) { skippedSize++; continue; }
    LIB.files.push({
      path,
      name: path.split('/').pop(),
      size: file.size,
      content: null,    // lazy load
      _file: file,      // keep reference for content fetch
    });
  }
  LIB.files.sort((a, b) => a.path.localeCompare(b.path));
  LIB.expanded = new Set([rootName]);
  LIB.source = 'live';   // 'live' = handle/files in memory, 'cache' = restored from IndexedDB
  renderLibrary();
  if (skippedSize) console.warn(`Library: skipped ${skippedSize} files exceeding ${LIB_MAX_FILE_BYTES/1024}kB`);

  // Eagerly read all file contents and cache them in IndexedDB.
  // Show progress in the count tag.
  await libCacheAllContents();
  await libPersistMetadata();
  if (LIB.fsHandle) {
    try { await libDbPutHandle(LIB.fsHandle); } catch (e) { console.warn('cant persist handle', e); }
  }
}

async function libCacheAllContents() {
  const tag = $('library-count');
  let done = 0;
  const total = LIB.files.length;
  const batch = [];
  for (const f of LIB.files) {
    if (!f._file) continue;
    try {
      const text = await f._file.text();
      f.content = text;
      batch.push({ path: f.path, name: f.name, size: f.size, content: text });
    } catch (e) {
      console.warn('Could not read file', f.path, e);
    }
    done++;
    if (done % 50 === 0 || done === total) {
      tag.textContent = `caching ${done}/${total}…`;
      // flush in chunks
      if (batch.length >= 50) {
        try { await libDbPutFilesBulk(batch.splice(0, batch.length)); } catch (e) { console.warn(e); }
      }
    }
  }
  if (batch.length) {
    try { await libDbPutFilesBulk(batch); } catch (e) { console.warn(e); }
  }
  renderLibrary();
}

async function libPersistMetadata() {
  try {
    await libDbPutMeta({
      rootName: LIB.rootName,
      fileList: LIB.files.map(f => ({ path: f.path, name: f.name, size: f.size })),
      timestamp: Date.now(),
    });
  } catch (e) { console.warn('persist meta failed', e); }
}

async function libRestoreFromCache() {
  // Try IndexedDB first (full content), fall back to nothing.
  try {
    const meta = await libDbGetMeta();
    if (!meta || !meta.fileList || !meta.fileList.length) return false;
    const cachedFiles = await libDbGetAllFiles();
    if (!cachedFiles.length) return false;
    const byPath = new Map(cachedFiles.map(f => [f.path, f]));
    LIB.rootName = meta.rootName || '';
    LIB.files = meta.fileList.map(m => {
      const cached = byPath.get(m.path);
      return {
        path: m.path,
        name: m.name,
        size: m.size,
        content: cached ? cached.content : null,
        _file: null,
        _ghost: !cached,    // ghost only if no cached content (shouldn't happen normally)
      };
    });
    LIB.expanded = new Set([LIB.rootName]);
    LIB.source = 'cache';
    // Try to restore the handle for live refresh capability
    try {
      LIB.fsHandle = await libDbGetHandle();
    } catch {}
    return true;
  } catch (e) {
    console.warn('cache restore failed', e);
    return false;
  }
}

$('lib-clear').onclick = async () => {
  LIB.files = []; LIB.rootName = ''; LIB.fsHandle = null; LIB.expanded.clear(); LIB.activePath = null; LIB.source = null;
  try { localStorage.removeItem(LIB_LS_KEY); } catch {}
  try { await libDbClearFiles(); } catch (e) { console.warn('clear db failed', e); }
  renderLibrary();
};

