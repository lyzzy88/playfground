};

/* Heuristic: detect what query language a rule text most likely is.
   Used to warn about language mismatches before parsing crashes. */
function detectRuleLangHint(text) {
  if (!text || !text.trim()) return null;
  const t = text.trim();
  // Sigma: starts with `title:` or `detection:` or `id:` or has `condition:` keyword
  if (/^[a-z_-]+\s*:/im.test(t.split('\n')[0]) &&
      /^\s*(detection|correlation|condition|logsource)\s*:/m.test(t)) {
    return 'sigma';
  }
  // BIOC YAML wrapper with query: |  → treat as XQL since we auto-unwrap
  if (/^\s*query\s*:\s*[|>]/m.test(t)) return 'xql';
  // Logpoint JSON/JSON5 alert rule: starts with `{` and has a "query" field
  if (t.startsWith('{') && /["']?query["']?\s*:\s*["']/.test(t)) return 'logpoint';
  // XQL: starts with "dataset =", "config", or "preset ="
  if (/^\s*(dataset|preset|config)\s*[=]?/i.test(t.split('\n')[0])) return 'xql';
  // KQL: pipe-prefixed `where`/`summarize`/`extend` early in the query
  if (/\|\s*(where|summarize|extend|project|join\s+kind=)/.test(t)) return 'kql';
  // SPL: pipe-prefixed `stats`/`eval`/`spath`
  if (/\|\s*(stats|eval|spath|rex|table)/.test(t)) return 'spl';
  return null;
}

function renderError(err) {
  $('results').innerHTML = '<div class="error-box"><strong>⚠ execution error</strong>' + escapeHtml(err.message || String(err)) + '</div>';
  $('rt-time').textContent = 'failed';
}
function escapeHtml(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

/* ─── RENDERER (universal) ─── */
function renderResults(res, events, elapsed, fmt, lang) {
  $('rt-time').textContent = elapsed.toFixed(1) + ' ms · ' + fmt + ' · ' + lang;
  // dispatch based on result kind
  if (res.kind === 'detection') {
    renderSigmaDetection(res.rule, res.result, events, elapsed, fmt, lang);
  } else if (res.kind === 'correlation') {
    renderSigmaCorrelation(res.result, events, elapsed, fmt, lang);
  } else if (res.kind === 'detection-query') {
    renderQueryDetection(res.result.results, events, elapsed, fmt, lang, ruleEl.value);
  } else if (res.kind === 'correlation-query') {
    renderQueryCorrelation(res.result, events, elapsed, fmt, lang, ruleEl.value);
  }
}

