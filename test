  if (node.type === 'const') return node.value ? '*:*' : '(NOT *:*)';
  if (node.type === 'not') return '(NOT ' + astToLucene(node.child) + ')';
  if (node.type === 'and') return '(' + astToLucene(node.left) + ' AND ' + astToLucene(node.right) + ')';
  if (node.type === 'or')  return '(' + astToLucene(node.left) + ' OR '  + astToLucene(node.right) + ')';
  if (node.type === 'sel') {
    const parts = [];
    for (const it of node.ast.items) {
      if (it.op) parts.push(astToLuceneSel(it));
      else parts.push(clauseToLucene(it.field, it.mods, it.values, it.all));
    }
    const glue = node.ast.op === 'and' ? ' AND ' : ' OR ';
    return parts.length > 1 ? '(' + parts.join(glue) + ')' : parts[0];
  }
