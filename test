/* ═══════════════════════════════════════════════════════════
   UNIFIED AST
   Node types:
     { type: 'cmp', field, op, values: [str], all?: bool }
       op ∈ =, !=, >, >=, <, <=, contains, startswith, endswith, re, exists
     { type: 'and'|'or', left, right }
     { type: 'not', child }
     { type: 'const', value: bool }
     { type: 'freetext', values: [str] }  — for Lucene/SPL/LP free keywords
