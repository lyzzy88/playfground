<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>SIGMA // PLAYGROUND</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/js-yaml/4.1.0/js-yaml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/json5/2.2.3/index.min.js"></script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #0e0e12;
    --bg-1:      #181820;
    --bg-2:      #23232c;
    --bg-input:  #0b0b10;
    --border:    #34343f;
    --border-hi: #54545f;
    --text:      #f2f2f4;
    --text-dim:  #b4b5bf;
    --text-faint:#878892;
    --amber:     #ffb73d;
    --amber-h:   #ffd27a;
    --amber-d:   #d48200;
    --amber-bg:  rgba(255,183,61,0.14);
    --green:     #2ee89a;
    --red:       #ff6681;
    --cyan:      #7fe4ff;
    --violet:    #c4b3ff;
  }

  html, body { height: 100%; background: var(--bg); color: var(--text); font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 12.5px; line-height: 1.5; overflow: hidden; }

  body::before { content:''; position: fixed; inset: 0; background: repeating-linear-gradient(0deg, transparent 0, transparent 2px, rgba(255,255,255,0.012) 2px, rgba(255,255,255,0.012) 3px); pointer-events: none; z-index: 1000; }
  body::after  { content:''; position: fixed; inset: 0; background: radial-gradient(ellipse at center, transparent 55%, rgba(0,0,0,0.55) 100%); pointer-events: none; z-index: 999; }

  .app { height: 100vh; display: grid; grid-template-rows: auto 1fr auto; }

  .topbar { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-bottom: 1px solid var(--border); background: var(--bg-1); }
  .brand { display: flex; align-items: baseline; gap: 14px; }
  .brand-mark { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 22px; letter-spacing: -0.02em; color: var(--text); }
  .brand-mark .slash { color: var(--amber); margin: 0 6px; }
  .brand-sub { color: var(--text-faint); font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; }
  .topbar-meta { display: flex; align-items: center; gap: 22px; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-dim); font-weight: 600; }
  .dot { display: inline-block; width: 7px; height: 7px; background: var(--green); box-shadow: 0 0 8px var(--green); margin-right: 8px; vertical-align: middle; animation: pulse 2.4s infinite; }
  @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }

  .main { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); overflow: hidden; }
  .col { display: flex; flex-direction: column; background: var(--bg); min-width: 0; }
  .col.left { display: grid; grid-template-rows: 1fr 1fr; gap: 1px; background: var(--border); }

  .panel { display: flex; flex-direction: column; background: var(--bg-1); min-height: 0; position: relative; }
  .panel:focus-within { box-shadow: inset 0 0 0 1px var(--amber-d); }
  .panel-head { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; border-bottom: 1px solid var(--border); background: var(--bg-2); gap: 10px; flex-wrap: wrap; }
  .panel-title { display: flex; align-items: center; gap: 10px; font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--text); font-weight: 700; white-space: nowrap; }
  .panel-title .tick { color: var(--amber); }
  .panel-tag { font-size: 10px; color: var(--text-dim); letter-spacing: 0.2em; text-transform: uppercase; font-weight: 500; }

  /* tabs */
  .tabs { display: flex; gap: 0; }
  .tab {
    background: transparent;
    border: 0; border-bottom: 2px solid transparent;
    padding: 8px 14px 10px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 700;
    letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--text-dim); cursor: pointer;
    transition: color 0.1s, border-color 0.1s;
  }
  .tab:hover { color: var(--text); }
  .tab.active { color: var(--amber); border-bottom-color: var(--amber); }
  .tab .badge-small { display: inline-block; margin-left: 8px; padding: 1px 6px; background: var(--bg-2); color: var(--text-faint); font-size: 9px; border: 1px solid var(--border); }
  .tab.active .badge-small { background: var(--amber-bg); color: var(--amber); border-color: var(--amber-d); }

  .editor-wrap { flex: 1; position: relative; overflow: hidden; background: var(--bg-input); }
  textarea.editor { width: 100%; height: 100%; background: transparent; color: var(--text); border: 0; outline: 0; padding: 16px 18px; font-family: 'JetBrains Mono', monospace; font-size: 12.5px; line-height: 1.65; resize: none; caret-color: var(--amber); white-space: pre; tab-size: 2; transition: box-shadow 0.1s; }
  textarea.editor::selection { background: var(--amber-bg); }
  textarea.editor::placeholder { color: var(--text-faint); }
  textarea.editor.drop-hover { box-shadow: inset 0 0 0 2px var(--amber); background: var(--amber-bg); }

  .toolbar { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
  .tb-btn, .tb-select { background: transparent; color: var(--text-dim); border: 1px solid var(--border); padding: 5px 9px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer; font-weight: 600; }
  .tb-btn:hover, .tb-select:hover { color: var(--amber); border-color: var(--amber-d); }
  .tb-select { appearance: none; background-image: linear-gradient(45deg, transparent 50%, var(--text-dim) 50%), linear-gradient(135deg, var(--text-dim) 50%, transparent 50%); background-position: calc(100% - 12px) 50%, calc(100% - 7px) 50%; background-size: 5px 5px, 5px 5px; background-repeat: no-repeat; padding-right: 24px; }
  .tb-sep { width: 1px; height: 16px; background: var(--border); margin: 0 2px; }
  .tb-btn.fileup { color: var(--amber); border-color: var(--amber-d); }
  .tb-btn.fileup:hover { background: var(--amber-bg); }

  .results { flex: 1; overflow-y: auto; padding: 18px; background: var(--bg-input); }
  .results::-webkit-scrollbar { width: 8px; }
  .results::-webkit-scrollbar-thumb { background: var(--border-hi); }

  .tab-panel { display: none; flex: 1; overflow: hidden; flex-direction: column; }
  .tab-panel.active { display: flex; }

  .empty { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--text-faint); text-align: center; gap: 14px; padding: 20px; }
  .empty .ascii { font-size: 10px; line-height: 1.15; white-space: pre; color: var(--border-hi); }
  .empty .msg { font-size: 11px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--text-dim); }
  .empty .hint { font-size: 11px; color: var(--text-faint); max-width: 380px; line-height: 1.65; }
  .empty .hint kbd { background: var(--bg-2); border: 1px solid var(--border); padding: 1px 6px; font-family: 'JetBrains Mono'; font-size: 10px; color: var(--amber); }

  .summary { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); margin-bottom: 18px; border: 1px solid var(--border); }
  .summary > div { background: var(--bg-2); padding: 12px 14px; }
  .stat-label { font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 6px; font-weight: 600; }
  .stat-val { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 22px; color: var(--text); }
  .stat-val.amber { color: var(--amber); }
  .stat-val.violet { color: var(--violet); }

  .event-row { border: 1px solid var(--border); margin-bottom: 10px; background: var(--bg-1); }
  .event-row.hit { border-color: var(--amber-d); box-shadow: inset 3px 0 0 var(--amber); }
  .event-row.miss { opacity: 0.55; }
  .event-head { display: flex; justify-content: space-between; align-items: center; padding: 10px 14px; border-bottom: 1px solid var(--border); background: var(--bg-2); cursor: pointer; user-select: none; gap: 10px; }
  .event-head:hover { background: #1d1d22; }
  .event-title { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; display: flex; gap: 12px; align-items: center; min-width: 0; }
  .event-title .ellip { color: var(--text-dim); font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 260px; }
  .badge { display: inline-block; padding: 3px 8px; font-size: 9.5px; letter-spacing: 0.25em; text-transform: uppercase; font-weight: 700; }
  .badge.hit { background: var(--amber); color: #1a0e00; }
  .badge.miss { background: transparent; color: var(--text-faint); border: 1px solid var(--border-hi); }
  .badge.corr { background: var(--violet); color: #1a0c33; }
  .event-body { padding: 10px 14px; display: none; }
  .event-row.open .event-body { display: block; }
  .event-body .kv { display: grid; grid-template-columns: 220px 1fr; gap: 4px 14px; font-size: 11.5px; }
  .event-body .k { color: var(--text-dim); word-break: break-all; font-weight: 500; }
  .event-body .v { color: var(--text); word-break: break-all; }
  .event-body .v.match { color: var(--amber); background: rgba(255,183,61,0.15); padding: 1px 5px; font-weight: 600; }

  .error-box { border: 1px solid var(--red); background: rgba(255,68,102,0.06); padding: 14px 16px; color: var(--red); font-size: 11.5px; }
  .error-box strong { display: block; font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase; margin-bottom: 6px; font-weight: 700; }

  /* TRANSLATE tab */
  .translate-head {
    padding: 14px 18px 6px;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }
  .translate-head b { color: var(--text); }
  .translate-head .meta { color: var(--text-faint); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; margin-top: 4px; }

  .backend-card {
    border: 1px solid var(--border);
    background: var(--bg-1);
    margin: 0 18px 14px;
  }
  .backend-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 9px 12px;
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
  }
  .backend-name {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--text);
  }
  .backend-name .sigil { color: var(--amber); margin-right: 8px; }
  .backend-name .fmt { color: var(--text-faint); font-weight: 500; margin-left: 6px; font-size: 9.5px; }
  .backend-copy {
    background: transparent;
    color: var(--text-dim);
    border: 1px solid var(--border-hi);
    padding: 4px 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px; letter-spacing: 0.22em; text-transform: uppercase;
    cursor: pointer; font-weight: 600;
  }
  .backend-copy:hover { color: var(--amber); border-color: var(--amber-d); }
  .backend-copy.copied { color: var(--green); border-color: var(--green); }
  .backend-query {
    padding: 12px 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    line-height: 1.6;
    color: var(--cyan);
    background: var(--bg-input);
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 320px;
    overflow-y: auto;
  }
  .backend-query::-webkit-scrollbar { width: 6px; height: 6px; }
  .backend-query::-webkit-scrollbar-thumb { background: var(--border-hi); }
  .backend-notes {
    padding: 8px 14px;
    border-top: 1px dashed var(--border);
    background: var(--bg-1);
    font-size: 10.5px;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    line-height: 1.6;
  }
  .backend-notes b { color: var(--amber); }
  .backend-query.error {
    color: var(--red);
    background: rgba(255,68,102,0.05);
  }

  .footer { display: flex; align-items: stretch; border-top: 1px solid var(--border); background: var(--bg-1); }
  .foot-info { flex: 1; padding: 10px 20px; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-dim); display: flex; align-items: center; gap: 22px; flex-wrap: wrap; font-weight: 600; }
  .foot-info span.sep { color: var(--text-faint); }
  .execute-btn { background: var(--amber); color: #1a0e00; border: 0; padding: 0 40px; font-family: 'JetBrains Mono', monospace; font-weight: 800; font-size: 13px; letter-spacing: 0.28em; text-transform: uppercase; cursor: pointer; transition: background 0.12s; min-width: 240px; }
  .execute-btn:hover { background: var(--amber-h); }
  .execute-btn:active { background: var(--amber-d); }

  .cond { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--cyan); background: rgba(102,224,255,0.06); padding: 2px 6px; border: 1px solid rgba(102,224,255,0.2); }
  .corr-chip { display: inline-block; padding: 2px 8px; font-size: 9.5px; letter-spacing: 0.25em; text-transform: uppercase; font-weight: 700; background: rgba(179,157,255,0.1); color: var(--violet); border: 1px solid rgba(179,157,255,0.3); margin-left: 6px; }

  .file-info { color: var(--text-dim); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; }
  .file-info b { color: var(--amber); font-weight: 600; }

  .group-row {
    border: 1px solid var(--border);
    margin-bottom: 10px;
    background: var(--bg-1);
  }
  .group-row.hit { border-color: var(--violet); box-shadow: inset 3px 0 0 var(--violet); }
  .group-row.miss { opacity: 0.55; }
  .group-head {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 14px; background: var(--bg-2); cursor: pointer; gap: 10px;
  }
  .group-head:hover { background: #1d1d22; }
  .group-key {
    font-size: 11px; letter-spacing: 0.1em;
    display: flex; align-items: center; gap: 12px;
  }
  .group-count {
    font-family: 'Syne', sans-serif; font-weight: 800; font-size: 15px;
  }
  .group-count.ok { color: var(--violet); }
  .group-count.no { color: var(--text-faint); }
  .group-body { padding: 10px 14px; display: none; border-top: 1px solid var(--border); }
  .group-row.open .group-body { display: block; }
  .group-body .sub { font-size: 11.5px; color: var(--text-dim); margin-bottom: 6px; letter-spacing: 0.05em; }
  .group-body ul { list-style: none; padding: 0; }
  .group-body li { padding: 4px 0; font-size: 11.5px; color: var(--text); border-bottom: 1px dashed var(--border); }
</style>
</head>
<body>
<div class="app">

  <header class="topbar">
    <div class="brand">
      <div class="brand-mark">SIGMA<span class="slash">//</span>PLAYGROUND</div>
      <div class="brand-sub">v0.3 · multi-format · correlation · backends</div>
    </div>
    <div class="topbar-meta">
      <div><span class="dot"></span>ENGINE READY</div>
      <div id="meta-events">EVENTS: 0</div>
      <div id="meta-rule">RULE: —</div>
    </div>
  </header>

  <main class="main">

    <div class="col left">

      <section class="panel">
        <div class="panel-head">
          <div class="panel-title"><span class="tick">▸</span> SIGMA RULE <span class="panel-tag">/ yaml · v2</span></div>
          <div class="toolbar">
            <button class="tb-btn fileup" id="btn-upload-rule">↥ FILE</button>
            <input type="file" id="file-rule" hidden accept=".yml,.yaml,.sigma,.txt" />
            <div class="tb-sep"></div>
            <button class="tb-btn" data-rule="rule1">PS_ENC</button>
            <button class="tb-btn" data-rule="rule2">NEW_SVC</button>
            <button class="tb-btn" data-rule="rule3">CURL/WGET</button>
            <button class="tb-btn" data-rule="rule4">SUDOERS</button>
            <button class="tb-btn" data-rule="rule5">⟳ CORR·COUNT</button>
            <button class="tb-btn" data-rule="rule6">⟳ CORR·TEMPORAL</button>
            <button class="tb-btn" id="btn-clear-rule">CLR</button>
          </div>
        </div>
        <div class="editor-wrap">
          <textarea id="rule" class="editor" spellcheck="false"></textarea>
        </div>
      </section>

      <section class="panel">
        <div class="panel-head">
          <div class="panel-title"><span class="tick">▸</span> TEST DATA <span class="panel-tag" id="format-tag">/ auto</span></div>
          <div class="toolbar">
            <select class="tb-select" id="data-format" title="Format">
              <option value="auto">AUTO</option>
              <option value="xml">XML</option>
              <option value="json">JSON</option>
              <option value="ndjson">NDJSON</option>
              <option value="json5">JSON5</option>
              <option value="auditd">AUDITD</option>
              <option value="laurel">LAUREL</option>
            </select>
            <button class="tb-btn fileup" id="btn-upload-data">↥ FILE</button>
            <input type="file" id="file-data" hidden multiple />
            <div class="tb-sep"></div>
            <button class="tb-btn" data-data="data1">WIN · PS</button>
            <button class="tb-btn" data-data="data2">WIN · SVC</button>
            <button class="tb-btn" data-data="data3">AUDITD</button>
            <button class="tb-btn" data-data="data4">LAUREL</button>
            <button class="tb-btn" data-data="data5">JSON</button>
            <button class="tb-btn" data-data="data6">BRUTE4625</button>
            <button class="tb-btn" id="btn-clear-data">CLR</button>
          </div>
        </div>
        <div class="editor-wrap">
          <textarea id="data" class="editor" spellcheck="false" placeholder="Drop files or paste XML / JSON / NDJSON / JSON5 / auditd / Laurel..."></textarea>
        </div>
      </section>

    </div>

    <section class="panel col right">
      <div class="panel-head">
        <div class="tabs">
          <button class="tab active" data-tab="analysis">ANALYSIS</button>
          <button class="tab" data-tab="translate">TRANSLATE<span class="badge-small" id="tab-badge">5</span></button>
        </div>
        <div class="panel-tag" id="rt-time">—</div>
      </div>

      <div class="tab-panel active" id="panel-analysis">
        <div class="results" id="results">
          <div class="empty">
            <div class="ascii">
   ┌─────────────────────────┐
   │   [ ] [ ] [ ]           │
   │   ▒▒▒▒▒▒▒▒▒▒▒▒          │
   │   ▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒      │
   │   ▒▒▒▒▒▒▒▒▒▒            │
   └─────────────────────────┘
            </div>
            <div class="msg">awaiting input</div>
            <div class="hint">
              Regel + Daten laden, dann <kbd>Ctrl</kbd>+<kbd>↵</kbd> oder <b style="color:var(--amber)">EXECUTE</b>.
              Tab <b style="color:var(--amber)">TRANSLATE</b> zeigt die Regel als Query in allen Backends.
            </div>
          </div>
        </div>
      </div>

      <div class="tab-panel" id="panel-translate">
        <div class="results" id="translate-out">
          <div class="empty">
            <div class="msg">load a rule</div>
            <div class="hint">
              Sobald eine valide Sigma-Regel im Editor steht, erscheinen hier die Queries für Elastic (Lucene), Splunk SPL, Sentinel KQL, Cortex XSIAM (XQL) und Logpoint — korrelationsfähig.
            </div>
          </div>
        </div>
      </div>

    </section>

  </main>

  <footer class="footer">
    <div class="foot-info">
      <div>LOCAL MODE</div><span class="sep">│</span>
      <div id="foot-file" class="file-info">NO FILE LOADED</div><span class="sep">│</span>
      <div id="foot-stat">IDLE</div>
    </div>
    <button id="execute" class="execute-btn">EXECUTE SIGMA ▶</button>
  </footer>

</div>

<script>
/* ═══════════════════════════════════════════════════════════
   SIGMA PLAYGROUND ENGINE  v0.3
   - multi-format parsers (xml/json/ndjson/json5/auditd/laurel)
   - sigma v2 correlation support
   - 5 backend converters
   ═══════════════════════════════════════════════════════════ */

/* ═════════ FLATTEN ═════════ */
function flatten(obj, prefix, out) {
  prefix = prefix || ''; out = out || {};
  if (obj === null || obj === undefined) return out;
  if (Array.isArray(obj)) {
    out[prefix] = obj.map(v => (v && typeof v === 'object') ? JSON.stringify(v) : String(v)).join(' ');
    obj.forEach((v, i) => {
      if (v && typeof v === 'object') flatten(v, prefix + '[' + i + ']', out);
      else out[prefix + '[' + i + ']'] = v;
    });
    if (obj.length && obj.every(v => v && typeof v === 'object' && !Array.isArray(v))) {
      const agg = {};
      for (const item of obj) for (const [k, v] of Object.entries(item)) {
        if (v === null || typeof v === 'object') continue;
        (agg[k] = agg[k] || []).push(String(v));
      }
      for (const [k, vals] of Object.entries(agg)) {
        const key = prefix + '.' + k;
        if (!(key in out)) out[key] = vals.join(' ');
      }
    }
    return out;
  }
  if (typeof obj !== 'object') { out[prefix] = obj; return out; }
  for (const [k, v] of Object.entries(obj)) {
    const key = prefix ? prefix + '.' + k : k;
    if (v !== null && typeof v === 'object') flatten(v, key, out);
    else out[key] = v;
  }
  return out;
}

/* ═════════ PARSERS ═════════ */
function parseXML(text) {
  const doc = new DOMParser().parseFromString(text, 'text/xml');
  const perr = doc.getElementsByTagName('parsererror');
  if (perr.length) throw new Error('XML: ' + perr[0].textContent.split('\n')[0]);
  const events = doc.getElementsByTagName('Event');
  const out = [];
  for (const ev of events) {
    const flat = {};
    const sys = ev.getElementsByTagName('System')[0];
    if (sys) for (const c of sys.children) {
      flat[c.tagName] = c.textContent.trim();
      for (const a of c.attributes) flat[c.tagName + '.' + a.name] = a.value;
    }
    const ed = ev.getElementsByTagName('EventData')[0];
    if (ed) for (const d of ed.getElementsByTagName('Data')) {
      const n = d.getAttribute('Name');
