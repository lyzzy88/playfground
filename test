function renderLibrary() {
  const tag = $('library-count');
  // Update refresh button state: only enabled when we have a usable handle
  const refreshBtn = $('lib-refresh');
  if (refreshBtn) {
    const canRefresh = !!LIB.fsHandle && !!window.showDirectoryPicker;
    refreshBtn.disabled = !canRefresh;
    refreshBtn.title = canRefresh
      ? 'Re-read folder from disk (live refresh)'
      : 'Refresh requires File System Access API (Chrome/Edge) and a folder picked via FOLDER';
  }

  if (!LIB.files.length) {
    tag.textContent = 'empty';
    libTreeEl.innerHTML = `<div class="library-empty">
        <div class="library-empty-msg">no folder loaded</div>
        <div class="library-empty-hint">
          Drag &amp; drop a folder anywhere here,<br/>
          or click <b style="color:var(--amber)">▣ FOLDER</b> to pick one.<br/><br/>
          <span style="color:var(--text-faint)">e.g. clone the sigmaHQ/sigma repo and load <code>rules/</code></span>
        </div>
      </div>`;
    return;
  }

  // Filter files
  const filtered = LIB.filter
    ? LIB.files.filter(f => f.path.toLowerCase().includes(LIB.filter))
    : LIB.files;

  tag.textContent = filtered.length === LIB.files.length
    ? `${LIB.files.length} files`
    : `${filtered.length} / ${LIB.files.length}`;

  if (!filtered.length) {
    libTreeEl.innerHTML = '<div class="library-empty"><div class="library-empty-msg">no match</div></div>';
    return;
  }

  // Source indicator
  const sourceClass = LIB.source === 'cache' ? 'cache' : 'live';
  const sourceText = LIB.source === 'cache'
    ? (LIB.fsHandle ? 'cached · click ↻ to refresh from disk' : 'cached · re-pick folder for live access')
    : 'live';
  const sourceHtml = `<div class="library-source ${sourceClass}">
    <span class="library-source-dot"></span>
    <span>${sourceText}</span>
  </div>`;

  // Build tree from paths
  const tree = libBuildTree(filtered);
  libTreeEl.innerHTML = sourceHtml + libRenderTreeNode(tree, '');
  // Wire up handlers
  libTreeEl.querySelectorAll('.lib-folder-head').forEach(el => {
    el.onclick = ev => {
      ev.stopPropagation();
      const path = el.dataset.path;
      const folder = el.parentElement;
      folder.classList.toggle('collapsed');
      if (folder.classList.contains('collapsed')) LIB.expanded.delete(path);
      else LIB.expanded.add(path);
    };
  });
  libTreeEl.querySelectorAll('.lib-file').forEach(el => {
    el.onclick = async () => {
      const path = el.dataset.path;
      await libOpenFile(path);
    };
  });
}

function libBuildTree(files) {
  // tree node: { name, path, dirs: Map<name,node>, files: [fileEntry] }
  const root = { name: LIB.rootName || '/', path: LIB.rootName || '', dirs: new Map(), files: [] };
  for (const f of files) {
    const parts = f.path.split('/');
    let node = root;
    // first part of path is rootName already
    let curPath = '';
    for (let i = 0; i < parts.length - 1; i++) {
      const p = parts[i];
      curPath = curPath ? curPath + '/' + p : p;
      if (!node.dirs.has(p)) {
        node.dirs.set(p, { name: p, path: curPath, dirs: new Map(), files: [] });
      }
      node = node.dirs.get(p);
    }
    node.files.push(f);
  }
  return root;
}

function libRenderTreeNode(node, indent) {
  let html = '';
  // skip rendering the synthetic root wrapper if it has only one folder child
  const renderHere = node.path !== '';  // root has empty path
  if (renderHere) {
    const collapsed = !LIB.expanded.has(node.path);
    const fileCount = libCountFiles(node);
    html += `<div class="lib-folder ${collapsed ? 'collapsed' : ''}">`;
    html += `<div class="lib-folder-head" data-path="${escapeHtml(node.path)}">
      <span class="lib-folder-arrow">▾</span>
      <span class="lib-folder-name">${escapeHtml(node.name)}/</span>
      <span class="lib-folder-count">${fileCount}</span>
    </div>`;
    html += `<div class="lib-folder-children">`;
  }
  // sort: dirs first (alpha), then files (alpha)
  const dirs = [...node.dirs.values()].sort((a, b) => a.name.localeCompare(b.name));
  const files = [...node.files].sort((a, b) => a.name.localeCompare(b.name));
  for (const d of dirs) html += libRenderTreeNode(d, indent + '  ');
  for (const f of files) {
    const isActive = LIB.activePath === f.path;
    const ext = (f.name.split('.').pop() || '').toLowerCase();
    const sizeKb = (f.size / 1024).toFixed(1);
    const ghost = f._ghost ? ' style="opacity:0.5"' : '';
    html += `<div class="lib-file ${isActive ? 'active' : ''}" data-path="${escapeHtml(f.path)}"${ghost}>
      <span class="lib-file-icon">${libIconFor(ext)}</span>
      <span class="lib-file-name">${escapeHtml(f.name)}</span>
      <span class="lib-file-meta">${sizeKb}k</span>
    </div>`;
  }
  if (renderHere) html += `</div></div>`;
  return html;
}

function libCountFiles(node) {
  let n = node.files.length;
  for (const d of node.dirs.values()) n += libCountFiles(d);
  return n;
}
function libIconFor(ext) {
  if (ext === 'yml' || ext === 'yaml' || ext === 'sigma') return '⊟';
  if (ext === 'json' || ext === 'ndjson' || ext === 'jsonl' || ext === 'json5') return '⊞';
  if (ext === 'md') return '#';
  if (ext === 'spl' || ext === 'kql' || ext === 'xql') return '∿';
  return '·';
}

async function libOpenFile(path) {
  const f = LIB.files.find(x => x.path === path);
  if (!f) return;
  if (f._ghost) {
    // Ghost entry from restored metadata - we can't load content
    renderError(new Error(`File "${f.path}" was restored from a previous session — please reload the folder to access content.`));
    return;
  }
  // Lazy load content
  if (!f.content && f._file) {
    f.content = await f._file.text();
  }
  if (!f.content) { renderError(new Error('Could not read file: ' + f.path)); return; }
  // Set active and load into editor
  LIB.activePath = path;
  ruleEl.value = f.content;
  // Detect language from extension or content
  const guessed = libGuessLang(f);
  if (guessed) {
    langSel.value = guessed;
    onLangChange();
  }
  updateMeta();
  renderLibrary();  // re-render to update active highlight
};

/* Restore on startup from IndexedDB (full content cached) */
(async () => {
  if (await libRestoreFromCache()) {
    renderLibrary();
  }
})();
</script>
</body>
</html>
