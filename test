<script>
/* ═══════════════════════════════════════════════════════════
   SIGMA PLAYGROUND ENGINE  v0.3
   - multi-format parsers (xml/json/ndjson/json5/auditd/laurel)
   - sigma v2 correlation support
   - 5 backend converters
   ═══════════════════════════════════════════════════════════ */

/* ═════════ FLATTEN ═════════ */
function flatten(obj, prefix, out) {
  prefix = prefix || ''; out = out || {};
  if (obj === null || obj === undefined) return out;
  if (Array.isArray(obj)) {
    out[prefix] = obj.map(v => (v && typeof v === 'object') ? JSON.stringify(v) : String(v)).join(' ');
    obj.forEach((v, i) => {
      if (v && typeof v === 'object') flatten(v, prefix + '[' + i + ']', out);
      else out[prefix + '[' + i + ']'] = v;
    });
    if (obj.length && obj.every(v => v && typeof v === 'object' && !Array.isArray(v))) {
      const agg = {};
      for (const item of obj) for (const [k, v] of Object.entries(item)) {
        if (v === null || typeof v === 'object') continue;
        (agg[k] = agg[k] || []).push(String(v));
      }
      for (const [k, vals] of Object.entries(agg)) {
        const key = prefix + '.' + k;
        if (!(key in out)) out[key] = vals.join(' ');
      }
    }
    return out;
  }
  if (typeof obj !== 'object') { out[prefix] = obj; return out; }
  for (const [k, v] of Object.entries(obj)) {
    const key = prefix ? prefix + '.' + k : k;
    if (v !== null && typeof v === 'object') flatten(v, key, out);
    else out[key] = v;
  }
  return out;
}

/* ═════════ PARSERS ═════════ */
function parseXML(text) {
  const doc = new DOMParser().parseFromString(text, 'text/xml');
  const perr = doc.getElementsByTagName('parsererror');
  if (perr.length) throw new Error('XML: ' + perr[0].textContent.split('\n')[0]);
  const events = doc.getElementsByTagName('Event');
  const out = [];
  for (const ev of events) {
    const flat = {};
    const sys = ev.getElementsByTagName('System')[0];
    if (sys) for (const c of sys.children) {
      flat[c.tagName] = c.textContent.trim();
      for (const a of c.attributes) flat[c.tagName + '.' + a.name] = a.value;
    }
    const ed = ev.getElementsByTagName('EventData')[0];
    if (ed) for (const d of ed.getElementsByTagName('Data')) {
      const n = d.getAttribute('Name');
      if (n) flat[n] = d.textContent.trim();
    }
    for (const c of ev.children) {
      if (c.tagName === 'System' || c.tagName === 'EventData') continue;
      if (c.children.length === 0) flat[c.tagName] = c.textContent.trim();
    }
    out.push(flat);
  }
  return out;
}
function parseJSON(text) { const o = JSON.parse(text); return (Array.isArray(o) ? o : [o]).map(e => flatten(e)); }
function parseNDJSON(text) {
  const out = [];
  text.split(/\r?\n/).forEach((line, idx) => {
    const t = line.trim();
    if (!t || t.startsWith('#') || t.startsWith('//')) return;
    try { out.push(flatten(JSON.parse(t))); }
    catch(e) { throw new Error('NDJSON line ' + (idx+1) + ': ' + e.message); }
  });
  return out;
}
function parseJSON5(text) { if (typeof JSON5 === 'undefined') throw new Error('JSON5 lib not loaded'); const o = JSON5.parse(text); return (Array.isArray(o) ? o : [o]).map(e => flatten(e)); }

function parseAuditd(text) {
  const reHead = /^(?:node=\S+\s+)?type=(\S+)\s+msg=audit\(([\d.]+):(\d+)\):\s*(.*)$/;
  const reKV = /(\w+)=(?:"([^"]*)"|'([^']*)'|(\S+))/g;
  const groups = new Map();
  for (const raw of text.split(/\r?\n/)) {
    const line = raw.trim();
    if (!line || line.startsWith('#')) continue;
    const m = line.match(reHead);
    if (!m) continue;
    const [, type, ts, serial, rest] = m;
    const key = ts + ':' + serial;
    let ev = groups.get(key);
    if (!ev) { ev = { _id: key, _timestamp: Number(ts), _serial: serial, _types: [], type }; groups.set(key, ev); }
    ev._types.push(type);
    let km; reKV.lastIndex = 0;
    while ((km = reKV.exec(rest))) {
      const k = km[1];
      const v = km[2] !== undefined ? km[2] : km[3] !== undefined ? km[3] : km[4];
      ev[type + '.' + k] = v;
      if (!(k in ev)) ev[k] = v;
    }
  }
  return Array.from(groups.values());
}
function parseLaurel(text) {
  const events = parseNDJSON(text);
  const alias = ['exe','comm','uid','euid','gid','egid','pid','ppid','key','tty','success','exit','auid','syscall','arch'];
  return events.map(e => {
    for (const a of alias) { const src = 'SYSCALL.' + a; if (src in e && !(a in e)) e[a] = e[src]; }
    if (!e.type) {
      if ('SYSCALL.syscall' in e || 'SYSCALL.exe' in e) e.type = 'SYSCALL';
      else if ('USER_ACCT.uid' in e) e.type = 'USER_ACCT';
    }
    return e;
  });
}
function parseEvents(text, format) {
  if (!text || !text.trim()) return [];
  const f = format === 'auto' ? detectFormat(text) : format;
  switch (f) {
    case 'xml': return parseXML(text);
    case 'json': return parseJSON(text);
    case 'ndjson': return parseNDJSON(text);
    case 'json5': return parseJSON5(text);
    case 'auditd': return parseAuditd(text);
    case 'laurel': return parseLaurel(text);
    default: throw new Error('Unknown format: ' + f);
  }
}
function detectFormat(text) {
  const t = text.trim();
  if (!t) return 'json';
  const head = t.slice(0, 2048);
  if (head.startsWith('<')) return 'xml';
  if (/^type=\S+\s+msg=audit\(/m.test(head)) return 'auditd';
  if (head.startsWith('[')) return 'json';
  if (head.startsWith('{')) {
    const lines = t.split(/\r?\n/).filter(l => l.trim());
    if (lines.length > 1 && lines.slice(0,3).every(l => l.trim().startsWith('{'))) {
      if (/"SYSCALL"\s*:\s*\{/.test(head) || /"EXECVE"\s*:\s*\{/.test(head)) return 'laurel';
      return 'ndjson';
    }
    return 'json';
  }
  return 'json5';
}

/* ═════════ SIGMA MATCH ═════════ */
function getField(event, path) { return (path in event) ? event[path] : undefined; }

function matchField(actual, expected, mods) {
  if (actual === undefined || actual === null) return { ok: false, hit: null };
  const a = String(actual);
  const vals = Array.isArray(expected) ? expected : [expected];
  const useAll = mods.includes('all');
  const ci = !mods.includes('cased');
  const check = v => {
    const vs = String(v);
    const A = ci ? a.toLowerCase() : a;
    const V = ci ? vs.toLowerCase() : vs;
    if (mods.includes('contains'))   return A.includes(V);
    if (mods.includes('startswith')) return A.startsWith(V);
    if (mods.includes('endswith'))   return A.endsWith(V);
    if (mods.includes('re'))         { try { return new RegExp(vs).test(a); } catch(e){ return false; } }
    if (mods.includes('gt'))         return Number(a) > Number(vs);
    if (mods.includes('lt'))         return Number(a) < Number(vs);
    if (mods.includes('gte'))        return Number(a) >= Number(vs);
    if (mods.includes('lte'))        return Number(a) <= Number(vs);
    return A === V;
  };
  const hits = vals.filter(check);
  const ok = useAll ? hits.length === vals.length : hits.length > 0;
  return { ok, hit: ok ? hits[0] : null };
}

function matchSelection(event, sel) {
  if (Array.isArray(sel)) {
    for (const s of sel) { const r = matchSelection(event, s); if (r.ok) return r; }
    return { ok: false, matches: [] };
  }
  const matches = [];
  for (const [full, expected] of Object.entries(sel)) {
    const parts = full.split('|');
    const field = parts[0];
    const mods = parts.slice(1);
    const actual = getField(event, field);
    const r = matchField(actual, expected, mods);
    if (!r.ok) return { ok: false, matches: [] };
    matches.push({ field, expected: r.hit, modifiers: mods, actual });
  }
  return { ok: true, matches };
}

function evalCondition(condition, sel) {
  const keys = Object.keys(sel);
  let e = ' ' + condition + ' ';
  e = e.replace(/\ball of them\b/gi, '(' + keys.join(' and ') + ')');
  e = e.replace(/\b1 of them\b/gi,   '(' + keys.join(' or ')  + ')');
  e = e.replace(/\bany of them\b/gi, '(' + keys.join(' or ')  + ')');
  e = e.replace(/\ball of ([a-zA-Z_][\w]*)\*/g, (_,p) => { const k = keys.filter(x => x.startsWith(p)); return k.length ? '(' + k.join(' and ') + ')' : 'false'; });
  e = e.replace(/\b1 of ([a-zA-Z_][\w]*)\*/g, (_,p) => { const k = keys.filter(x => x.startsWith(p)); return k.length ? '(' + k.join(' or ') + ')' : 'false'; });
  for (const k of keys) {
    const re = new RegExp('\\b' + k.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + '\\b', 'g');
    e = e.replace(re, sel[k].ok ? 'true' : 'false');
  }
  e = e.replace(/\band\b/gi, '&&').replace(/\bor\b/gi, '||').replace(/\bnot\b/gi, '!');
  if (!/^[\s()!&|truefals]*$/i.test(e.replace(/true|false/gi,''))) throw new Error('Unsupported condition: ' + condition);
  try { return Function('"use strict";return (' + e + ')')(); }
  catch(err) { throw new Error('Condition eval failed: ' + condition); }
}

function runDetection(rule, events) {
  const det = rule.detection;
  if (!det) throw new Error('Rule "' + (rule.title||'') + '" has no detection');
  const cond = det.condition;
  if (!cond) throw new Error('Rule "' + (rule.title||'') + '" has no condition');
  return events.map((ev, idx) => {
    const s = {};
    for (const [k, v] of Object.entries(det)) {
      if (k === 'condition' || k === 'timeframe') continue;
      s[k] = matchSelection(ev, v);
    }
    const hit = evalCondition(cond, s);
    return { idx, event: ev, selResults: s, hit };
  });
}

/* ═════════ RULE GRAPH ═════════
   Parses multi-doc YAML. Classifies each document:
   - correlation rule  → has `correlation:` block
   - detection rule    → has `detection:` block
   Correlations reference detection rules by `name` or `id`.
*/
function parseRuleGraph(yamlText) {
  let docs;
  try { docs = jsyaml.loadAll(yamlText).filter(d => d && typeof d === 'object'); }
  catch (e) { throw new Error('YAML parse: ' + e.message); }
  if (!docs.length) throw new Error('No rule documents found');

  const detections = [];
  const correlations = [];
  const byName = {};
  for (const d of docs) {
    if (d.correlation) correlations.push(d);
    else if (d.detection) {
      detections.push(d);
      if (d.name) byName[d.name] = d;
      if (d.id)   byName[d.id]   = d;
    }
  }
  return { docs, detections, correlations, byName };
}

/* ═════════ TIMESPAN PARSER ═════════ */
function parseTimespan(ts) {
  if (ts === undefined || ts === null) return null;
  if (typeof ts === 'number') return ts * 1000; // assume seconds
  const m = String(ts).match(/^(\d+)\s*(s|m|h|d)?$/i);
  if (!m) return null;
  const n = parseInt(m[1], 10);
  const u = (m[2] || 's').toLowerCase();
  const mult = { s: 1000, m: 60000, h: 3600000, d: 86400000 }[u];
  return n * mult;
}

/* ═════════ EVENT TIMESTAMP ═════════ */
const TIME_FIELDS = ['@timestamp','timestamp','TimeCreated.SystemTime','TimeCreated','time','eventTime','_timestamp','ts','date','SYSCALL.timestamp','ID'];
function eventTime(ev, idx) {
  if (ev._timestamp) return ev._timestamp * (ev._timestamp < 1e12 ? 1000 : 1);
  for (const f of TIME_FIELDS) {
    if (ev[f] !== undefined) {
      const v = ev[f];
      const n = Date.parse(v);
      if (!isNaN(n)) return n;
      const num = Number(v);
      if (!isNaN(num)) return num * (num < 1e12 ? 1000 : 1);
    }
  }
  // Laurel IDs look like "1729689600.123:987" – take the float
  if (ev.ID && /^[\d.]+:\d+$/.test(String(ev.ID))) {
    return parseFloat(String(ev.ID).split(':')[0]) * 1000;
  }
  return idx; // fallback: insertion order
}

/* ═════════ CORRELATION ENGINE ═════════ */
function checkCorrCondition(count, cond) {
  if (!cond || typeof cond !== 'object') return false;
  if ('gte' in cond) return count >= cond.gte;
  if ('gt'  in cond) return count >  cond.gt;
  if ('lte' in cond) return count <= cond.lte;
  if ('lt'  in cond) return count <  cond.lt;
  if ('eq'  in cond) return count === cond.eq;
  return false;
}

function runCorrelation(corrRule, graph, events) {
  const c = corrRule.correlation;
  const type = c.type || 'event_count';
  const refs = (c.rules || []).map(n => {
    const r = graph.byName[n];
    if (!r) throw new Error('Correlation refs unknown rule: ' + n);
    return r;
  });
  if (!refs.length) throw new Error('Correlation has no referenced rules');

  const timespan = parseTimespan(c.timespan);
  const groupBy = c['group-by'] || c.group_by || [];
  const cond = c.condition || {};

  // evaluate each referenced rule; collect matching event indices
  const perRule = refs.map(r => {
    const results = runDetection(r, events);
    return { rule: r, hits: results.filter(x => x.hit).map(x => x.idx) };
  });

  // groupKey for event
  const keyOf = idx => {
    const ev = events[idx];
    return groupBy.map(f => String(ev[f] !== undefined ? ev[f] : '∅')).join(' ┃ ');
  };

  // ---- TYPE: event_count ----
  if (type === 'event_count') {
    const src = perRule[0].hits; // sigma v2: event_count uses a single rule
    const groups = new Map();
    for (const idx of src) {
      const k = keyOf(idx);
      (groups.get(k) || groups.set(k, []).get(k)).push(idx);
    }
    const out = [];
    for (const [k, idxs] of groups) {
      // slide a window of `timespan` over the indices; find max count
      const times = idxs.map(i => eventTime(events[i], i)).sort((a,b) => a-b);
      const orderedIdx = idxs.slice().sort((a,b) => eventTime(events[a], a) - eventTime(events[b], b));
      let maxCount = timespan ? 1 : times.length;
      let windowIdxs = timespan ? [] : orderedIdx.slice();
      if (timespan) {
        let left = 0;
        for (let right = 0; right < times.length; right++) {
          while (times[right] - times[left] > timespan) left++;
          if (right - left + 1 > maxCount) { maxCount = right - left + 1; windowIdxs = orderedIdx.slice(left, right + 1); }
        }
      }
      out.push({
        groupKey: k, groupFields: groupBy, count: maxCount,
        hit: checkCorrCondition(maxCount, cond),
        eventIdxs: windowIdxs,
        allIdxs: idxs,
      });
    }
    return { type, groups: out, rule: corrRule, perRule, cond };
  }

  // ---- TYPE: value_count ----
  if (type === 'value_count') {
    const field = c.field || c['field-name'];
    if (!field) throw new Error('value_count needs `field`');
    const src = perRule[0].hits;
    const groups = new Map();
    for (const idx of src) {
      const k = keyOf(idx);
      (groups.get(k) || groups.set(k, { vals: new Set(), idxs: [] })).vals.add(String(events[idx][field]));
      groups.get(k).idxs.push(idx);
    }
    const out = [];
    for (const [k, {vals, idxs}] of groups) {
      out.push({
        groupKey: k, groupFields: groupBy, count: vals.size,
        hit: checkCorrCondition(vals.size, cond),
        eventIdxs: idxs, allIdxs: idxs, valueField: field, valueSet: [...vals]
      });
    }
    return { type, groups: out, rule: corrRule, perRule, cond, field };
  }

  // ---- TYPE: temporal / temporal_ordered ----
  if (type === 'temporal' || type === 'temporal_ordered') {
    const ordered = (type === 'temporal_ordered');
    // group hit-indices per rule per groupKey
    const groupMap = new Map();
    perRule.forEach((pr, ruleIdx) => {
      for (const idx of pr.hits) {
        const k = keyOf(idx);
        if (!groupMap.has(k)) groupMap.set(k, refs.map(() => []));
        groupMap.get(k)[ruleIdx].push({ idx, t: eventTime(events[idx], idx) });
      }
    });
    const out = [];
    for (const [k, perRuleIdxs] of groupMap) {
      const allPresent = perRuleIdxs.every(arr => arr.length > 0);
      if (!allPresent) {
        out.push({ groupKey: k, groupFields: groupBy, count: 0, hit: false, eventIdxs: [], allIdxs: perRuleIdxs.flat().map(x=>x.idx), perRuleHits: perRuleIdxs.map(a=>a.length) });
        continue;
      }
      // find any combination within timespan (and ordered, if required)
      let found = null;
      if (ordered) {
        // try to pick earliest increasing chain
        let prev = -Infinity;
        const picks = [];
        for (const arr of perRuleIdxs) {
          const sorted = arr.slice().sort((a,b) => a.t - b.t);
          const next = sorted.find(x => x.t >= prev);
          if (!next) { picks.length = 0; break; }
          picks.push(next); prev = next.t;
        }
        if (picks.length === perRuleIdxs.length) {
          if (!timespan || picks[picks.length - 1].t - picks[0].t <= timespan) found = picks.map(p => p.idx);
        }
      } else {
        // any window containing at least one from each rule
        const all = perRuleIdxs.flatMap((arr, ri) => arr.map(x => ({ ri, ...x }))).sort((a, b) => a.t - b.t);
        for (let i = 0; i < all.length; i++) {
          const seen = new Map(); // ri -> idx
          seen.set(all[i].ri, all[i].idx);
          for (let j = i + 1; j < all.length; j++) {
            if (timespan && all[j].t - all[i].t > timespan) break;
            if (!seen.has(all[j].ri)) seen.set(all[j].ri, all[j].idx);
            if (seen.size === perRuleIdxs.length) { found = [...seen.values()]; break; }
          }
          if (found) break;
        }
      }
      out.push({
        groupKey: k, groupFields: groupBy,
        count: found ? found.length : 0,
        hit: !!found,
        eventIdxs: found || [],
        allIdxs: perRuleIdxs.flat().map(x => x.idx),
        perRuleHits: perRuleIdxs.map(a => a.length)
      });
    }
    return { type, groups: out, rule: corrRule, perRule, cond, ordered };
  }

  throw new Error('Unsupported correlation type: ' + type);
}

/* ═════════ TOP-LEVEL RUNNER ═════════ */
function runRule(yamlText, events) {
  const graph = parseRuleGraph(yamlText);
  // primary rule = last document (Sigma v2 convention: correlation at bottom)
  const primary = graph.docs[graph.docs.length - 1];
  if (primary.correlation) {
    return { kind: 'correlation', graph, result: runCorrelation(primary, graph, events) };
  }
  // single detection
  if (primary.detection) {
    return { kind: 'detection', graph, rule: primary, result: runDetection(primary, events) };
  }
  throw new Error('Primary rule has neither `detection` nor `correlation`');
}

/* ═══════════════════════════════════════════════════════════
   BACKEND CONVERTERS
   ═══════════════════════════════════════════════════════════ */

/* ---- small helpers used by converters ---- */
function normalizeSelectionValues(v) { return Array.isArray(v) ? v : [v]; }
function escLuceneValue(v, wildcard) {
  // escape for Lucene; caller decides whether to wrap in quotes
  let s = String(v);
  // escape backslash first
  s = s.replace(/\\/g, '\\\\');
  // escape reserved chars
  s = s.replace(/([+\-!(){}\[\]^"~:\/])/g, '\\$1');
  // escape AND/OR/NOT when bare
  return s;
}
function quoteStr(v) { return '"' + String(v).replace(/\\/g, '\\\\').replace(/"/g, '\\"') + '"'; }
function kqlStr(v)   { return '"' + String(v).replace(/\\/g, '\\\\').replace(/"/g, '\\"') + '"'; }
function isNumericish(v) { return typeof v === 'number' || /^-?\d+(?:\.\d+)?$/.test(String(v)); }

/* build an AST from a selection so we can render it per backend */
function selectionToAST(sel) {
  // returns { op: 'and'|'or', items: [clause|AST] }
  // clause: { field, mods: string[], values: string[] }
  if (Array.isArray(sel)) return { op: 'or', items: sel.map(selectionToAST) };
  const items = [];
  for (const [full, expected] of Object.entries(sel)) {
    const parts = full.split('|');
    const field = parts[0];
    const mods = parts.slice(1);
    const values = normalizeSelectionValues(expected);
    items.push({ field, mods, values, all: mods.includes('all') });
  }
  return { op: 'and', items };
}

/* render condition: given AST per selection name and a condition string,
   returns a backend-agnostic tree of { type: 'sel'|'and'|'or'|'not', ... } */
function renderCondition(condition, selAsts) {
  const keys = Object.keys(selAsts);
  let e = ' ' + condition + ' ';
  e = e.replace(/\ball of them\b/gi, '(' + keys.join(' AND ') + ')');
  e = e.replace(/\b1 of them\b/gi, '(' + keys.join(' OR ') + ')');
  e = e.replace(/\bany of them\b/gi, '(' + keys.join(' OR ') + ')');
  e = e.replace(/\ball of ([a-zA-Z_][\w]*)\*/g, (_,p) => {
    const k = keys.filter(x => x.startsWith(p));
    return k.length ? '(' + k.join(' AND ') + ')' : 'FALSE';
  });
  e = e.replace(/\b1 of ([a-zA-Z_][\w]*)\*/g, (_,p) => {
    const k = keys.filter(x => x.startsWith(p));
    return k.length ? '(' + k.join(' OR ') + ')' : 'FALSE';
  });
  // parse expression
  return parseBoolExpr(e.trim(), selAsts);
}
function parseBoolExpr(src, selAsts) {
  // Shunting-yard-ish: tokenize then build tree
  const tokens = [];
  let i = 0;
  while (i < src.length) {
    const c = src[i];
    if (/\s/.test(c)) { i++; continue; }
    if (c === '(' || c === ')') { tokens.push(c); i++; continue; }
    // word
    let j = i;
    while (j < src.length && /[\w*]/.test(src[j])) j++;
    const word = src.slice(i, j);
    i = j;
    const lower = word.toLowerCase();
    if (lower === 'and' || lower === 'or' || lower === 'not') tokens.push(lower.toUpperCase());
    else tokens.push({ type: 'sel', name: word });
  }
  // recursive descent
  let pos = 0;
  function peek() { return tokens[pos]; }
  function eat(t) { if (peek() === t) { pos++; return true; } return false; }
  function parseOr() {
    let left = parseAnd();
    while (peek() === 'OR') { pos++; const right = parseAnd(); left = { type: 'or', left, right }; }
    return left;
  }
  function parseAnd() {
    let left = parseNot();
    while (peek() === 'AND') { pos++; const right = parseNot(); left = { type: 'and', left, right }; }
    return left;
  }
  function parseNot() {
    if (peek() === 'NOT') { pos++; return { type: 'not', child: parseNot() }; }
    return parseAtom();
  }
  function parseAtom() {
    const t = peek();
    if (t === '(') { pos++; const node = parseOr(); eat(')'); return node; }
    if (typeof t === 'object' && t.type === 'sel') { pos++;
      if (t.name === 'FALSE') return { type: 'const', value: false };
      if (t.name === 'TRUE')  return { type: 'const', value: true };
      const ast = selAsts[t.name];
      if (!ast) return { type: 'const', value: false };
      return { type: 'sel', name: t.name, ast };
    }
    return { type: 'const', value: false };
  }
  return parseOr();
}

/* ───── ELASTIC LUCENE ───── */
function clauseToLucene(field, mods, values, all) {
  const parts = values.map(v => {
    if (mods.includes('re')) return field + ':/' + String(v).replace(/\//g,'\\/') + '/';
    if (mods.includes('gt'))  return field + ':>'  + v;
    if (mods.includes('gte')) return field + ':>=' + v;
    if (mods.includes('lt'))  return field + ':<'  + v;
    if (mods.includes('lte')) return field + ':<=' + v;
    let s = String(v);
    // lucene escape, then add wildcards
    const esc = escLuceneValue(s);
    if (mods.includes('contains'))   return field + ':*' + esc + '*';
    if (mods.includes('startswith')) return field + ':'  + esc + '*';
    if (mods.includes('endswith'))   return field + ':*' + esc;
    // numeric bare, string quoted
    if (isNumericish(v)) return field + ':' + v;
    return field + ':"' + String(v).replace(/\\/g,'\\\\').replace(/"/g,'\\"') + '"';
  });
  const joined = parts.join(all ? ' AND ' : ' OR ');
  return parts.length > 1 ? '(' + joined + ')' : joined;
}
function astToLucene(node) {
  if (node.type === 'const') return node.value ? '*:*' : '(NOT *:*)';
  if (node.type === 'not') return '(NOT ' + astToLucene(node.child) + ')';
  if (node.type === 'and') return '(' + astToLucene(node.left) + ' AND ' + astToLucene(node.right) + ')';
  if (node.type === 'or')  return '(' + astToLucene(node.left) + ' OR '  + astToLucene(node.right) + ')';
  if (node.type === 'sel') {
    const parts = [];
    for (const it of node.ast.items) {
      if (it.op) parts.push(astToLuceneSel(it));
      else parts.push(clauseToLucene(it.field, it.mods, it.values, it.all));
    }
    const glue = node.ast.op === 'and' ? ' AND ' : ' OR ';
    return parts.length > 1 ? '(' + parts.join(glue) + ')' : parts[0];
  }
  return '';
}
function astToLuceneSel(astNode) {
  const parts = astNode.items.map(it => it.op ? astToLuceneSel(it) : clauseToLucene(it.field, it.mods, it.values, it.all));
  const glue = astNode.op === 'and' ? ' AND ' : ' OR ';
  return parts.length > 1 ? '(' + parts.join(glue) + ')' : parts[0];
}
function toLucene(rule) {
  const selAsts = {};
  for (const [k, v] of Object.entries(rule.detection)) {
    if (k === 'condition' || k === 'timeframe') continue;
    selAsts[k] = selectionToAST(v);
  }
  const tree = renderCondition(rule.detection.condition, selAsts);
  return astToLucene(tree);
}

/* ───── SPLUNK SPL ───── */
function clauseToSPL(field, mods, values, all) {
  const parts = values.map(v => {
    if (mods.includes('re')) return field + '=' + quoteStr(String(v)); // approx: use regex command separately
    if (mods.includes('gt'))  return field + '>'  + v;
    if (mods.includes('gte')) return field + '>=' + v;
    if (mods.includes('lt'))  return field + '<'  + v;
    if (mods.includes('lte')) return field + '<=' + v;
    const sv = String(v);
    if (mods.includes('contains'))   return field + '=' + quoteStr('*' + sv + '*');
    if (mods.includes('startswith')) return field + '=' + quoteStr(sv + '*');
    if (mods.includes('endswith'))   return field + '=' + quoteStr('*' + sv);
    if (isNumericish(v)) return field + '=' + v;
    return field + '=' + quoteStr(sv);
  });
  const joined = parts.join(all ? ' AND ' : ' OR ');
  return parts.length > 1 ? '(' + joined + ')' : joined;
}
function astToSPL(node) {
  if (node.type === 'const') return node.value ? '*' : 'NOT *';
  if (node.type === 'not') return 'NOT (' + astToSPL(node.child) + ')';
  if (node.type === 'and') return '(' + astToSPL(node.left) + ' AND ' + astToSPL(node.right) + ')';
  if (node.type === 'or')  return '(' + astToSPL(node.left) + ' OR '  + astToSPL(node.right) + ')';
  if (node.type === 'sel') {
    return renderSelSPL(node.ast);
  }
  return '';
}
function renderSelSPL(astNode) {
  const parts = astNode.items.map(it => it.op ? renderSelSPL(it) : clauseToSPL(it.field, it.mods, it.values, it.all));
  const glue = astNode.op === 'and' ? ' AND ' : ' OR ';
  return parts.length > 1 ? '(' + parts.join(glue) + ')' : parts[0];
}
function toSPL(rule) {
  const selAsts = {};
  for (const [k, v] of Object.entries(rule.detection)) {
    if (k === 'condition' || k === 'timeframe') continue;
    selAsts[k] = selectionToAST(v);
  }
  const tree = renderCondition(rule.detection.condition, selAsts);
  return astToSPL(tree);
}

/* ───── SENTINEL KQL (Microsoft) ───── */
function clauseToKQL(field, mods, values, all) {
  const parts = values.map(v => {
    const sv = String(v);
    if (mods.includes('re')) return field + ' matches regex ' + kqlStr(sv);
    if (mods.includes('gt'))  return field + ' > ' + (isNumericish(v) ? v : kqlStr(sv));
    if (mods.includes('gte')) return field + ' >= ' + (isNumericish(v) ? v : kqlStr(sv));
    if (mods.includes('lt'))  return field + ' < ' + (isNumericish(v) ? v : kqlStr(sv));
    if (mods.includes('lte')) return field + ' <= ' + (isNumericish(v) ? v : kqlStr(sv));
    const ci = mods.includes('cased') ? '_cs' : '';
    if (mods.includes('contains'))   return field + ' contains'   + ci + ' ' + kqlStr(sv);
    if (mods.includes('startswith')) return field + ' startswith' + ci + ' ' + kqlStr(sv);
    if (mods.includes('endswith'))   return field + ' endswith'   + ci + ' ' + kqlStr(sv);
    if (isNumericish(v)) return field + ' == ' + v;
    return field + ' =~ ' + kqlStr(sv); // =~ is case-insensitive equals
  });
  const joined = parts.join(all ? ' and ' : ' or ');
  return parts.length > 1 ? '(' + joined + ')' : joined;
}
function astToKQL(node) {
  if (node.type === 'const') return node.value ? 'true' : 'false';
  if (node.type === 'not') return 'not (' + astToKQL(node.child) + ')';
  if (node.type === 'and') return '(' + astToKQL(node.left) + ' and ' + astToKQL(node.right) + ')';
  if (node.type === 'or')  return '(' + astToKQL(node.left) + ' or '  + astToKQL(node.right) + ')';
  if (node.type === 'sel') return renderSelKQL(node.ast);
  return '';
}
function renderSelKQL(astNode) {
  const parts = astNode.items.map(it => it.op ? renderSelKQL(it) : clauseToKQL(it.field, it.mods, it.values, it.all));
  const glue = astNode.op === 'and' ? ' and ' : ' or ';
  return parts.length > 1 ? '(' + parts.join(glue) + ')' : parts[0];
}
function toKQL(rule) {
  const selAsts = {};
  for (const [k, v] of Object.entries(rule.detection)) {
    if (k === 'condition' || k === 'timeframe') continue;
    selAsts[k] = selectionToAST(v);
  }
  const tree = renderCondition(rule.detection.condition, selAsts);
  const table = guessTable(rule);
  return table + '\n| where ' + astToKQL(tree);
}
function guessTable(rule) {
  const ls = rule.logsource || {};
  if (ls.product === 'windows') {
    if (ls.service === 'security') return 'SecurityEvent';
    if (ls.service === 'sysmon')   return 'Event // Sysmon';
    return 'SecurityEvent';
  }
  if (ls.product === 'linux') return 'Syslog';
  return 'SecurityEvent';
}

/* ───── CORTEX XSIAM / XDR (XQL) ───── */
function clauseToXQL(field, mods, values, all) {
  const parts = values.map(v => {
    const sv = String(v);
    if (mods.includes('re')) return field + ' ~= ' + kqlStr(sv);
    if (mods.includes('gt'))  return field + ' > '  + (isNumericish(v) ? v : kqlStr(sv));
    if (mods.includes('gte')) return field + ' >= ' + (isNumericish(v) ? v : kqlStr(sv));
    if (mods.includes('lt'))  return field + ' < '  + (isNumericish(v) ? v : kqlStr(sv));
    if (mods.includes('lte')) return field + ' <= ' + (isNumericish(v) ? v : kqlStr(sv));
    if (mods.includes('contains'))   return field + ' contains '   + kqlStr(sv);
    if (mods.includes('startswith')) return 'incidr(' + field + ', ' + kqlStr(sv) + ')' ; // XQL lacks prefix op; fallback to regex
    if (mods.includes('endswith'))   return field + ' ~= '         + kqlStr('.*' + sv.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + '$');
    if (isNumericish(v)) return field + ' = ' + v;
    return field + ' = ' + kqlStr(sv);
  });
  const joined = parts.join(all ? ' and ' : ' or ');
  return parts.length > 1 ? '(' + joined + ')' : joined;
}
function astToXQL(node) {
  if (node.type === 'const') return node.value ? 'true' : 'false';
  if (node.type === 'not') return 'not (' + astToXQL(node.child) + ')';
  if (node.type === 'and') return '(' + astToXQL(node.left) + ' and ' + astToXQL(node.right) + ')';
  if (node.type === 'or')  return '(' + astToXQL(node.left) + ' or '  + astToXQL(node.right) + ')';
  if (node.type === 'sel') return renderSelXQL(node.ast);
  return '';
}
function renderSelXQL(astNode) {
  const parts = astNode.items.map(it => it.op ? renderSelXQL(it) : clauseToXQL(it.field, it.mods, it.values, it.all));
  const glue = astNode.op === 'and' ? ' and ' : ' or ';
  return parts.length > 1 ? '(' + parts.join(glue) + ')' : parts[0];
}
function toXQL(rule) {
  const selAsts = {};
  for (const [k, v] of Object.entries(rule.detection)) {
    if (k === 'condition' || k === 'timeframe') continue;
    selAsts[k] = selectionToAST(v);
  }
  const tree = renderCondition(rule.detection.condition, selAsts);
  const ls = rule.logsource || {};
  const ds = ls.product === 'windows' ? 'xdr_data' : ls.product === 'linux' ? 'xdr_data' : 'xdr_data';
  return 'dataset = ' + ds + '\n| filter ' + astToXQL(tree);
}

/* ───── LOGPOINT ───── */
function clauseToLP(field, mods, values, all) {
  const parts = values.map(v => {
    const sv = String(v);
    if (mods.includes('re'))  return field + '=' + quoteStr(sv);
    if (mods.includes('gt'))  return field + '>'  + (isNumericish(v) ? v : quoteStr(sv));
    if (mods.includes('gte')) return field + '>=' + (isNumericish(v) ? v : quoteStr(sv));
    if (mods.includes('lt'))  return field + '<'  + (isNumericish(v) ? v : quoteStr(sv));
    if (mods.includes('lte')) return field + '<=' + (isNumericish(v) ? v : quoteStr(sv));
    if (mods.includes('contains'))   return field + '=' + quoteStr('*' + sv + '*');
    if (mods.includes('startswith')) return field + '=' + quoteStr(sv + '*');
    if (mods.includes('endswith'))   return field + '=' + quoteStr('*' + sv);
    if (isNumericish(v)) return field + '=' + v;
    return field + '=' + quoteStr(sv);
  });
  const joined = parts.join(all ? ' AND ' : ' OR ');
  return parts.length > 1 ? '(' + joined + ')' : joined;
}
function astToLP(node) {
  if (node.type === 'const') return node.value ? '*' : '-*';
  if (node.type === 'not') return '-(' + astToLP(node.child) + ')';
  if (node.type === 'and') return '(' + astToLP(node.left) + ' ' + astToLP(node.right) + ')';
  if (node.type === 'or')  return '(' + astToLP(node.left) + ' OR '  + astToLP(node.right) + ')';
  if (node.type === 'sel') return renderSelLP(node.ast);
  return '';
}
function renderSelLP(astNode) {
  const parts = astNode.items.map(it => it.op ? renderSelLP(it) : clauseToLP(it.field, it.mods, it.values, it.all));
  const glue = astNode.op === 'and' ? ' ' : ' OR ';
  return parts.length > 1 ? '(' + parts.join(glue) + ')' : parts[0];
}
function toLogpoint(rule) {
  const selAsts = {};
  for (const [k, v] of Object.entries(rule.detection)) {
    if (k === 'condition' || k === 'timeframe') continue;
    selAsts[k] = selectionToAST(v);
  }
  const tree = renderCondition(rule.detection.condition, selAsts);
  return astToLP(tree);
}

/* ═════════ CORRELATION CONVERTERS ═════════ */
function corrOpSigma(cond) {
  if ('gte' in cond) return { op: '>=', n: cond.gte };
  if ('gt'  in cond) return { op: '>',  n: cond.gt };
  if ('lte' in cond) return { op: '<=', n: cond.lte };
  if ('lt'  in cond) return { op: '<',  n: cond.lt };
  if ('eq'  in cond) return { op: '==', n: cond.eq };
  return { op: '>=', n: 1 };
}
function corrToLucene(corr, graph) {
  const ref = graph.byName[corr.correlation.rules[0]];
  if (!ref) return '# unresolved rule: ' + corr.correlation.rules[0];
  const base = toLucene(ref);
  return '# base query (index-time)\n' + base + '\n# correlation: cannot be expressed in Lucene alone — use ES|QL / Kibana watcher:\n# | STATS count = COUNT(*) BY ' + (corr.correlation['group-by'] || []).join(', ') + '\n# | WHERE count ' + corrOpSigma(corr.correlation.condition).op + ' ' + corrOpSigma(corr.correlation.condition).n;
}
function corrToSPL(corr, graph) {
  const c = corr.correlation;
  const ref = graph.byName[c.rules[0]];
  if (!ref) return '# unresolved rule';
  const base = toSPL(ref);
  const { op, n } = corrOpSigma(c.condition);
  const ts = c.timespan ? ('earliest=-' + c.timespan + ' ') : '';
  if (c.type === 'value_count') {
    return ts + base + '\n| stats dc(' + c.field + ') as cnt by ' + (c['group-by']||[]).join(', ') +
           '\n| where cnt ' + op + ' ' + n;
  }
  return ts + base + '\n| stats count as cnt by ' + (c['group-by']||[]).join(', ') +
         '\n| where cnt ' + op + ' ' + n;
}
function corrToKQL(corr, graph) {
  const c = corr.correlation;
  const ref = graph.byName[c.rules[0]];
  if (!ref) return '// unresolved rule';
  const base = toKQL(ref);
  const { op, n } = corrOpSigma(c.condition);
  const span = c.timespan || '1h';
  const binExpr = 'bin(TimeGenerated, ' + span + ')';
  if (c.type === 'value_count') {
    return base + '\n| summarize cnt = dcount(' + c.field + ') by ' + (c['group-by']||[]).concat([binExpr]).join(', ') +
           '\n| where cnt ' + op + ' ' + n;
  }
  return base + '\n| summarize cnt = count() by ' + (c['group-by']||[]).concat([binExpr]).join(', ') +
         '\n| where cnt ' + op + ' ' + n;
}
function corrToXQL(corr, graph) {
  const c = corr.correlation;
  const ref = graph.byName[c.rules[0]];
  if (!ref) return '// unresolved rule';
  const base = toXQL(ref);
  const { op, n } = corrOpSigma(c.condition);
  if (c.type === 'value_count') {
    return base + '\n| comp count_distinct(' + c.field + ') as cnt by ' + (c['group-by']||[]).join(', ') +
           '\n| filter cnt ' + op + ' ' + n;
  }
  return base + '\n| comp count() as cnt by ' + (c['group-by']||[]).join(', ') +
         '\n| filter cnt ' + op + ' ' + n;
}
function corrToLogpoint(corr, graph) {
  const c = corr.correlation;
  const ref = graph.byName[c.rules[0]];
  if (!ref) return '# unresolved rule';
  const base = toLogpoint(ref);
  const { op, n } = corrOpSigma(c.condition);
  if (c.type === 'value_count') {
    return base + '\n| chart distinct_count(' + c.field + ') as cnt by ' + (c['group-by']||[]).join(', ') +
           '\n| filter cnt ' + op + ' ' + n;
  }
  return base + '\n| chart count() as cnt by ' + (c['group-by']||[]).join(', ') +
         '\n| filter cnt ' + op + ' ' + n;
}

