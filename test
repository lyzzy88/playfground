      if (t.name === 'TRUE')  return { type: 'const', value: true };
      const ast = selAsts[t.name];
      if (!ast) return { type: 'const', value: false };
      return { type: 'sel', name: t.name, ast };
    }
    return { type: 'const', value: false };
