  try {
    const events = parseEvents(dataEl.value, fmtSel.value);
    const lang = langSel.value;

    // Detect language mismatch: user pasted YAML but selected a query language, etc.
    const hint = detectRuleLangHint(ruleEl.value);
    if (hint && hint !== lang && lang !== 'sigma') {
      // YAML with `title:`/`detection:` keys but we're set to a query language
      throw new Error(
        `Language mismatch: the rule looks like ${hint.toUpperCase()} but the editor is set to ${lang.toUpperCase()}. ` +
        `Switch the language dropdown to ${hint.toUpperCase()} and try again.`
      );
    }

    const res = runRule(lang, ruleEl.value, events);
    const fmt = fmtSel.value === 'auto' ? detectFormat(dataEl.value) : fmtSel.value;
    renderResults(res, events, performance.now() - t0, fmt, lang);
