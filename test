function describeEvent(e) {
  if (!e) return '';
  if (e.EventID) return 'EventID=' + e.EventID + (e.Computer ? ' @ ' + e.Computer : '') + (e.TargetUserName ? ' · ' + e.TargetUserName : '');
  if (e.exe) return e.exe + (e.comm ? ' (' + e.comm + ')' : '');
  if (e.type) return 'auditd ' + e.type + (e._serial ? ' #' + e._serial : '');
  const k = Object.keys(e).find(x => !x.startsWith('_'));
  return k ? (k + '=' + String(e[k]).slice(0, 80)) : '';
}

function renderSigmaEventBody(r) {
  const matchedFields = {};
  for (const [,sr] of Object.entries(r.selResults)) if (sr.ok) for (const m of sr.matches) matchedFields[m.field] = true;
  const rows = [];
  for (const k of Object.keys(r.event).filter(x => !x.startsWith('_')).sort()) {
    const v = r.event[k];
    if (v === undefined || v === null) continue;
    const isMatch = k in matchedFields;
    rows.push('<div class="k">' + escapeHtml(k) + '</div><div class="v ' + (isMatch?'match':'') + '">' + escapeHtml(v) + '</div>');
  }
  const selHtml = Object.entries(r.selResults).map(([k, v]) =>
    '<div style="margin-top:4px;"><span style="color:' + (v.ok?'var(--amber)':'var(--text-dim)') + ';">' + (v.ok?'✓':'✗') + ' ' + escapeHtml(k) + '</span></div>'
  ).join('');
  return '<div class="kv">' + rows.join('') + '</div>' +
    '<div style="margin-top:12px;padding-top:10px;border-top:1px dashed var(--border);font-size:10.5px;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-dim);">Selections</div>' + selHtml;
}

function renderPlainEventBody(event) {
  const rows = [];
  for (const k of Object.keys(event).filter(x => !x.startsWith('_')).sort()) {
    const v = event[k];
    if (v === undefined || v === null) continue;
    rows.push('<div class="k">' + escapeHtml(k) + '</div><div class="v">' + escapeHtml(v) + '</div>');
  }
  return '<div class="kv">' + rows.join('') + '</div>';
}

/* ─── TRANSLATE TAB (any → any) ─── */
function renderTranslate() {
  const out = $('translate-out');
  const sourceLang = langSel.value;

  // try to parse current rule into a generic pipeline AST
  let pipeline, parseErr;
  try { pipeline = ruleToPipeline(sourceLang, ruleEl.value); }
  catch (err) { parseErr = err.message; }

  if (parseErr) {
    out.innerHTML = `<div class="empty">
      <div class="msg">parse error</div>
      <div class="hint" style="color:var(--red)">${escapeHtml(parseErr)}</div>
    </div>`;
    return;
  }

  // Targets = all languages except the source
  const TARGETS = [
    { id:'sigma',    name:'SIGMA',    fmt:'yaml',          note:'Best-effort: pure AND-of-cmp detection logic translates cleanly. Aggregations become a v2 correlation rule.' },
    { id:'lucene',   name:'ELASTIC',  fmt:'Lucene',        note:'Aggregations require ES|QL or Watcher. Joins not expressible in Lucene.' },
    { id:'spl',      name:'SPLUNK',   fmt:'SPL',           note:'`alter` becomes `| spath` / `| eval`. Joins use `| join`.' },
    { id:'kql',      name:'SENTINEL', fmt:'KQL',           note:'`alter` becomes `| extend parse_json(...)`. Replace `YourTable` with your table.' },
    { id:'xql',      name:'CORTEX',   fmt:'XSIAM · XQL',   note:'Native target — alters use `->`, joins preserve `type=` option.' },
    { id:'logpoint', name:'LOGPOINT', fmt:'LP Query',      note:'Aggregations become `| chart`. Field aliases need a process plugin.' },
  ];

  // Stats / source description
  const aggStr = pipeline.agg ? `${pipeline.agg.type}(${pipeline.agg.field || '*'}) by ${(pipeline.agg.by || []).join(', ')}` : '';
  const flags = [];
  if (pipeline.alters && pipeline.alters.length) flags.push(`${pipeline.alters.length} alter`);
  if (pipeline.joins && pipeline.joins.length)   flags.push(`${pipeline.joins.length} join`);
  if (pipeline.postFilters && pipeline.postFilters.length) flags.push(`${pipeline.postFilters.length} post-filter`);
  const flagsHtml = flags.length ? `<span class="corr-chip">${flags.join(' · ')}</span>` : '';
  const aggHtml = aggStr ? `<span class="corr-chip">${escapeHtml(aggStr)}</span>` : '';

  let html = `
    <div class="translate-head">
      <div>▸ source: <span class="lang-chip">${sourceLang.toUpperCase()}</span> ${aggHtml} ${flagsHtml}</div>
      <div class="meta">Cross-language conversion · review output before deploying</div>
    </div>
  `;

  for (const t of TARGETS) {
    if (t.id === sourceLang) continue;  // don't show source as a target

    let query, err;
    try { query = pipelineToLang(pipeline, t.id, sourceLang); }
    catch (e) { err = e.message; }

    html += `
      <div class="backend-card">
        <div class="backend-head">
          <div class="backend-name"><span class="sigil">▸</span>${escapeHtml(t.name)}<span class="fmt">· ${escapeHtml(t.fmt)}</span></div>
          <div class="backend-actions">
            <button class="backend-use" data-backend="${t.id}" title="Load this query into the editor and switch to ${t.id}">USE</button>
            <button class="backend-copy" data-backend="${t.id}">COPY</button>
          </div>
        </div>
        <pre class="backend-query ${err?'error':''}" id="q-${t.id}">${escapeHtml(err || query || '(empty)')}</pre>
        <div class="backend-notes"><b>NOTE</b> · ${escapeHtml(t.note)}</div>
      </div>`;
  }
  out.innerHTML = html;

  // USE button: load query into editor and switch language
  document.querySelectorAll('.backend-use').forEach(btn => {
    btn.onclick = () => {
      const id = btn.dataset.backend;
      const q = document.getElementById('q-' + id).textContent;
      if (!q || q === '(empty)') return;
      ruleEl.value = q;
      langSel.value = id;
      onLangChange();
      updateMeta();
      // visual feedback then switch back to ANALYSIS
      const orig = btn.textContent;
      btn.textContent = '✓ LOADED';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = orig;
        btn.classList.remove('copied');
        document.querySelector('.tab[data-tab="analysis"]').click();
      }, 600);
    };
  });

  document.querySelectorAll('.backend-copy').forEach(btn => {
    btn.onclick = () => {
      const id = btn.dataset.backend;
      const q = document.getElementById('q-' + id).textContent;
      const orig = btn.textContent;
      const onOk = () => { btn.textContent = '✓ COPIED'; btn.classList.add('copied'); setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1200); };
      const onFail = () => { btn.textContent = '⚠ COPY FAILED'; setTimeout(() => { btn.textContent = orig; }, 1500); };
      try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(q).then(onOk).catch(() => {
            try {
              const ta = document.createElement('textarea');
              ta.value = q; document.body.appendChild(ta); ta.select();
              document.execCommand('copy'); document.body.removeChild(ta); onOk();
            } catch { onFail(); }
          });
        } else {
          const ta = document.createElement('textarea');
          ta.value = q; document.body.appendChild(ta); ta.select();
          document.execCommand('copy'); document.body.removeChild(ta); onOk();
        }
      } catch { onFail(); }
    };
  });
}

