    if (n.op === '<')  return `${f}<`  + (isNum(v) ? v : escStr(sv));
    if (n.op === '<=') return `${f}<=` + (isNum(v) ? v : escStr(sv));
    if (n.op === 'contains')   return `${f}=${escStr('*' + sv + '*')}`;
    if (n.op === 'startswith') return `${f}=${escStr(sv + '*')}`;
    if (n.op === 'endswith')   return `${f}=${escStr('*' + sv)}`;
    if (isNum(v)) return `${f}=${v}`;
    return `${f}=${escStr(sv)}`;
  });
  return parts.length > 1 ? '(' + parts.join(n.all ? ' ' : ' OR ') + ')' : parts[0];
}
function pipelineToLogpoint(p) {
  const lines = [astToLPStr(p.base)];
  if (p.alters && p.alters.length) {
    lines.push('# Logpoint: field aliases must be defined via a process plugin or normalisation package:');
    for (const a of p.alters) {
      lines.push(`#   ${a.target} ← ${describeAlterExpr(a.expr)}`);
    }
  }
  if (p.agg) {
    const aggs = p.agg.aggs || [{ kind: p.agg.type, field: p.agg.field, alias: p.agg.alias || 'cnt' }];
    const aggStr = aggs.map(a => a.kind === 'count' ? `count() as ${a.alias}` :
                                  a.kind === 'dcount' ? `distinct_count(${a.field}) as ${a.alias}` :
                                  `${a.kind}(${a.field}) as ${a.alias}`).join(', ');
    lines.push(`| chart ${aggStr} by ${(p.agg.by || []).join(', ')}`);
    if (p.agg.having) lines.push(`| filter ${p.agg.having.field} ${p.agg.having.op} ${p.agg.having.n}`);
  }
  if (p.joins && p.joins.length) lines.push('# Joins not natively supported in Logpoint queries — use a correlation rule.');
  return lines.join('\n');
}

/* Human-readable description of an alter expression — used by renderers
   that don't have a 1:1 native equivalent (Logpoint, Lucene, Sigma). */
function describeAlterExpr(expr) {
  if (!expr) return '?';
  if (expr.kind === 'literal')  return JSON.stringify(expr.value);
  if (expr.kind === 'field')    return expr.name;
  if (expr.kind === 'time')     return '_time';
  if (expr.kind === 'jsonPath') return `${expr.sourceField}.${expr.path}`;
  if (expr.kind === 'call') {
    if (expr.fn === 'arrayfilter') {
      const arr = (expr.args[0] || []).map(t => t.value).join('');
      const pred = (expr.args[1] || []).map(t => t.value).join(' ');
      return `arrayfilter(${arr}, ${pred})  // returns elements of ${arr} where predicate matches`;
    }
    if (expr.fn === 'arraylength' || expr.fn === 'array_length') {
      const arr = (expr.args[0] || []).map(t => t.value).join('');
      return `length of array ${arr}`;
    }
    if (expr.fn === 'coalesce') {
      const args = (expr.args || []).map(a => a.map(t => t.value).join('')).join(', ');
      return `coalesce(${args})`;
    }
    const args = (expr.args || []).map(a => a.map(t => t.value).join('')).join(', ');
    return `${expr.fn}(${args})`;
  }
  return '<unknown>';
}

/* ─── Render → Sigma (best-effort) ─── */
function pipelineToSigma(p, sourceLang) {
  const detName = 'converted_detection_' + Math.random().toString(36).slice(2, 8);
  const detLines = [];
  detLines.push('title: Converted from ' + (sourceLang || 'query'));
  detLines.push('id: ' + sigmaUuid4());
  detLines.push('name: ' + detName);
  detLines.push('description: Auto-generated translation. Review and adapt logsource/fields before deployment.');
  detLines.push('status: experimental');
  detLines.push('logsource:');
  detLines.push('  product: generic');

  // Decompose AST into positive selections + negative filters
  const decomp = decomposeForSigma(p.base);

  detLines.push('detection:');
  if (decomp.notes.length) {
    for (const n of decomp.notes) detLines.push('  # ' + n);
  }

  if (decomp.positive && Object.keys(decomp.positive).length) {
    detLines.push('  selection:');
    emitSigmaMap(decomp.positive, detLines, '    ');
  } else {
    detLines.push('  selection:');
    detLines.push('    # No positive condition could be extracted');
    detLines.push('    {}');
  }

  // Filter blocks (negations)
  let filterIdx = 0;
  const filterNames = [];
  for (const fblock of decomp.negatives) {
    filterIdx++;
    const fname = 'filter_' + filterIdx;
    filterNames.push(fname);
    detLines.push('  ' + fname + ':');
    emitSigmaMap(fblock, detLines, '    ');
  }

  let condition = 'selection';
  for (const fn of filterNames) condition += ' and not ' + fn;
  detLines.push('  condition: ' + condition);
  detLines.push('falsepositives:');
  detLines.push('  - Unknown');
  detLines.push('level: medium');

  if (!p.agg) {
    if (p.joins && p.joins.length) {
      detLines.push('# Note: source query had joins. Sigma has no join construct - the join logic is not preserved.');
    }
    return detLines.join('\n');
  }

  // Add a correlation document
  const corrLines = [];
  corrLines.push('---');
  corrLines.push('title: Correlation - ' + (sourceLang || 'query'));
  corrLines.push('id: ' + sigmaUuid4());
  corrLines.push('status: experimental');
  corrLines.push('correlation:');
  corrLines.push('  type: ' + (p.agg.type === 'dcount' ? 'value_count' : 'event_count'));
  corrLines.push('  rules:');
  corrLines.push('    - ' + detName);
  if (p.agg.by && p.agg.by.length) {
    corrLines.push('  group-by:');
    for (const f of p.agg.by) corrLines.push('    - ' + f);
  }
  if (p.agg.type === 'dcount' && p.agg.field) {
    corrLines.push('  field: ' + p.agg.field);
  }
  // Try to find a window from postFilters or default to 1h
  corrLines.push('  timespan: 1h  # adjust to match source window');
  if (p.agg.having) {
    corrLines.push('  condition:');
    corrLines.push('    ' + opToSigmaKey(p.agg.having.op) + ': ' + p.agg.having.n);
  } else {
    corrLines.push('  condition:');
    corrLines.push('    gte: 1');
  }
  if (p.joins && p.joins.length) {
    corrLines.push('# Note: source query had joins. Sigma has no join construct - the join logic is not preserved.');
  }
  return detLines.concat(corrLines).join('\n');
}

/* Walk the AST and split into a positive selection map and a list of negative
   filter maps. Returns { positive, negatives, notes }. */
function decomposeForSigma(node) {
  const positive = {};
  const negatives = [];
  const notes = [];
  function visit(n, intoPositive) {
    if (!n) return;
    if (n.type === 'const') return;  // truth, no-op
    if (n.type === 'and') {
      visit(n.left, intoPositive);
      visit(n.right, intoPositive);
      return;
    }
    if (n.type === 'or') {
      // OR can be expressed as multiple selections, but our flat model only handles one.
      // Emit a note and try to merge values as alternatives where possible.
      const merged = sigmaSelectionFromOr(n);
      if (merged && intoPositive) {
        // fold into positive map
        for (const [k, v] of Object.entries(merged)) {
          if (k in positive) {
            const prev = Array.isArray(positive[k]) ? positive[k] : [positive[k]];
            const cur  = Array.isArray(v) ? v : [v];
            positive[k] = prev.concat(cur);
          } else positive[k] = v;
        }
      } else {
        notes.push('OR expression could not be cleanly translated; review manually');
      }
      return;
    }
    if (n.type === 'not') {
      // negative filter
      const filt = sigmaSelectionFromAst(n.child);
      if (filt && Object.keys(filt).length) {
        negatives.push(filt);
      } else {
        notes.push('Negation could not be translated cleanly; review manually');
      }
      return;
    }
    if (n.type === 'cmp') {
      // List references can't be expressed in Sigma — skip with a note
      if (n.op === '__listref' || n.op === '__listref_not') {
        notes.push('List reference "' + (n.listRef || '?') + '" on ' + n.field + ' (' + (n.op === '__listref' ? 'IN' : 'NOT IN') + ') - resolve manually in target SIEM');
        return;
      }
      // Skip __fn: tagged values - they're time/calculation functions
      const vals = (n.values || []).filter(v => !String(v).startsWith('__fn:'));
      if (!vals.length) {
        notes.push('Filter on ' + n.field + ' uses a time/function value (e.g. ago()) - move to Sigma timeframe');
        return;
      }
      let key = n.field;
      const mod = sigmaModForOp(n.op);
      if (mod) key = key + '|' + mod;
      if (intoPositive) {
        if (key in positive) {
          const prev = Array.isArray(positive[key]) ? positive[key] : [positive[key]];
          positive[key] = prev.concat(vals);
        } else {
          positive[key] = vals.length === 1 ? vals[0] : vals;
        }
      }
      return;
    }
    if (n.type === 'expr-cmp') {
      notes.push('Expression comparison (e.g. timestamp_diff) is not expressible in Sigma');
      return;
    }
    if (n.type === 'freetext') {
      const vals = n.values || [];
      if (vals.length && intoPositive) {
        positive['keywords'] = vals.length === 1 ? vals[0] : vals;
      }
      return;
    }
  }
  visit(node, true);
  return { positive, negatives, notes };
}

function sigmaSelectionFromOr(node) {
  // Best-effort: if every leaf of OR is a cmp on the same field, merge into a value list
  const leaves = [];
  function collect(n) {
    if (!n) return false;
    if (n.type === 'or') return collect(n.left) && collect(n.right);
    if (n.type === 'cmp') { leaves.push(n); return true; }
    return false;
  }
  if (!collect(node)) return null;
  if (!leaves.length) return null;
  const sameField = leaves.every(l => l.field === leaves[0].field && l.op === leaves[0].op);
  if (!sameField) return null;
  let key = leaves[0].field;
  const mod = sigmaModForOp(leaves[0].op);
  if (mod) key = key + '|' + mod;
  const vals = leaves.flatMap(l => (l.values || []).filter(v => !String(v).startsWith('__fn:')));
  return { [key]: vals };
}

function emitSigmaMap(map, lines, indent) {
  for (const [k, v] of Object.entries(map)) {
    if (Array.isArray(v)) {
      lines.push(`${indent}${k}:`);
      for (const x of v) lines.push(`${indent}  - ${sigmaQuote(x)}`);
    } else {
      lines.push(`${indent}${k}: ${sigmaQuote(v)}`);
    }
  }
}

function sigmaUuid4() {
  // RFC 4122 v4 UUID. crypto API may not be present in old contexts; fallback to Math.random.
  if (typeof crypto !== 'undefined' && crypto.getRandomValues) {
    const buf = new Uint8Array(16);
    crypto.getRandomValues(buf);
    buf[6] = (buf[6] & 0x0f) | 0x40;
    buf[8] = (buf[8] & 0x3f) | 0x80;
    const hex = [...buf].map(b => b.toString(16).padStart(2, '0')).join('');
    return [hex.slice(0,8), hex.slice(8,12), hex.slice(12,16), hex.slice(16,20), hex.slice(20)].join('-');
  }
  let s = '';
  for (let i = 0; i < 32; i++) {
    if (i === 8 || i === 12 || i === 16 || i === 20) s += '-';
    let r = Math.floor(Math.random() * 16);
    if (i === 12) r = 4;
    else if (i === 16) r = (r & 0x3) | 0x8;
    s += r.toString(16);
  }
  return s;
}

function sigmaSelectionFromAst(node) {
  if (!node) return null;
  const out = {};
  function walk(n) {
    if (!n) return false;
    if (n.type === 'and') return walk(n.left) && walk(n.right);
    if (n.type === 'cmp') {
      let key = n.field;
      const mod = sigmaModForOp(n.op);
      if (mod) key = key + '|' + mod;
      const vals = (n.values || []).filter(v => !String(v).startsWith('__fn:')).map(String);
      if (!vals.length) return false;
      if (key in out) {
        const prev = Array.isArray(out[key]) ? out[key] : [out[key]];
        out[key] = prev.concat(vals);
      } else {
        out[key] = vals.length === 1 ? vals[0] : vals;
      }
      return true;
    }
    return false;
  }
  return walk(node) ? out : null;
}
function sigmaModForOp(op) {
  return { 'contains':'contains', 'startswith':'startswith', 'endswith':'endswith', 're':'re',
           '>':'gt', '>=':'gte', '<':'lt', '<=':'lte' }[op] || null;
}
function sigmaQuote(v) {
  const s = String(v);
  if (/^[\w\-\.\/:\\]+$/.test(s)) return s;
  return "'" + s.replace(/'/g, "''") + "'";
}
function opToSigmaKey(op) {
  return { '>':'gt', '>=':'gte', '<':'lt', '<=':'lte', '=':'eq' }[op] || 'gte';
}

/* ─── Universal "translate any AST to language X" ─── */
function pipelineToLang(pipeline, targetLang, sourceLang) {
  switch (targetLang) {
    case 'lucene':   return pipelineToLucene(pipeline);
    case 'spl':      return pipelineToSPL(pipeline);
    case 'kql':      return pipelineToKQL(pipeline);
    case 'xql':      return pipelineToXQL(pipeline);
    case 'logpoint': return pipelineToLogpoint(pipeline);
    case 'sigma':    return pipelineToSigma(pipeline, sourceLang);
    default: throw new Error('Unknown target language: ' + targetLang);
  }
}

/* ─── Convert any rule (sigma OR native) into a generic pipeline AST ─── */
function ruleToPipeline(lang, text) {
  if (!text || !text.trim()) throw new Error('Query is empty');
  if (lang === 'sigma') {
    const graph = parseRuleGraph(text);
    const primary = graph.docs[graph.docs.length - 1];
    if (primary.detection) {
      const sel = {};
      for (const [k, v] of Object.entries(primary.detection)) {
        if (k === 'condition' || k === 'timeframe') continue;
        sel[k] = sigmaSelectionToAst(v);
      }
      const base = sigmaConditionToAst(primary.detection.condition || 'selection', sel);
      return { base };
    }
    if (primary.correlation) {
      // Take first referenced detection rule + add agg from correlation
      const ref = graph.byName[primary.correlation.rules[0]];
      if (!ref) throw new Error('Correlation rule references unknown sub-rule');
      const subPipeline = ruleToPipeline('sigma', jsyaml.dump(ref));
      const c = primary.correlation;
      const aggType = c.type === 'value_count' ? 'dcount' : 'count';
      const { op, n } = corrOpSigma(c.condition || {});
      subPipeline.agg = {
        type: aggType,
        field: c.field || null,
        alias: 'cnt',
        by: c['group-by'] || [],
        having: { field: 'cnt', op, n },
        aggs: [{ kind: aggType, field: c.field || null, alias: 'cnt' }],
      };
      return subPipeline;
    }
    throw new Error('Sigma rule has neither detection nor correlation');
  }
  const parser = LANG_PARSERS[lang];
  if (!parser) throw new Error('Unknown language: ' + lang);
  return parser(text);
}

