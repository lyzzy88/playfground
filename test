/* ═══════════════════════════════════════════════════════════
   LIBRARY: Folder loading, tree view, file picking
   - Drag&Drop a folder anywhere on the library panel (works in all browsers)
   - Or click "FOLDER" button: uses File System Access API (Chrome/Edge) for
     persistent access, falls back to webkitdirectory <input> elsewhere
   - Tree groups files by path; click a file → loads into rule editor + sets language
   ═══════════════════════════════════════════════════════════ */
/* ─── IndexedDB layer for library persistence ─── */
const LIB_DB_NAME = 'sigma_playground_lib';
const LIB_DB_VERSION = 1;
const LIB_STORE_FILES = 'files';     // key: path, value: { path, content, size, mtime }
const LIB_STORE_META  = 'meta';      // key: 'meta', value: { rootName, hasHandle }
const LIB_STORE_HANDLE = 'handle';   // key: 'root', value: FileSystemDirectoryHandle

function libDbOpen() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open(LIB_DB_NAME, LIB_DB_VERSION);
    req.onupgradeneeded = e => {
      const db = e.target.result;
      if (!db.objectStoreNames.contains(LIB_STORE_FILES))  db.createObjectStore(LIB_STORE_FILES, { keyPath: 'path' });
      if (!db.objectStoreNames.contains(LIB_STORE_META))   db.createObjectStore(LIB_STORE_META);
      if (!db.objectStoreNames.contains(LIB_STORE_HANDLE)) db.createObjectStore(LIB_STORE_HANDLE);
    };
    req.onsuccess = () => resolve(req.result);
    req.onerror = () => reject(req.error);
  });
}
function libDbTx(db, stores, mode) {
  return db.transaction(stores, mode);
}
async function libDbPutFile(file) {
  const db = await libDbOpen();
  return new Promise((res, rej) => {
    const tx = libDbTx(db, [LIB_STORE_FILES], 'readwrite');
    tx.objectStore(LIB_STORE_FILES).put(file);
    tx.oncomplete = () => { db.close(); res(); };
    tx.onerror = () => { db.close(); rej(tx.error); };
  });
}
async function libDbPutFilesBulk(files) {
  const db = await libDbOpen();
  return new Promise((res, rej) => {
    const tx = libDbTx(db, [LIB_STORE_FILES], 'readwrite');
    const store = tx.objectStore(LIB_STORE_FILES);
    for (const f of files) store.put(f);
    tx.oncomplete = () => { db.close(); res(); };
    tx.onerror = () => { db.close(); rej(tx.error); };
  });
}
async function libDbGetFile(path) {
  const db = await libDbOpen();
  return new Promise((res, rej) => {
    const tx = libDbTx(db, [LIB_STORE_FILES], 'readonly');
    const req = tx.objectStore(LIB_STORE_FILES).get(path);
    req.onsuccess = () => { db.close(); res(req.result || null); };
    req.onerror = () => { db.close(); rej(req.error); };
  });
}
async function libDbGetAllFiles() {
  const db = await libDbOpen();
  return new Promise((res, rej) => {
    const tx = libDbTx(db, [LIB_STORE_FILES], 'readonly');
    const req = tx.objectStore(LIB_STORE_FILES).getAll();
    req.onsuccess = () => { db.close(); res(req.result || []); };
    req.onerror = () => { db.close(); rej(req.error); };
  });
}
async function libDbClearFiles() {
  const db = await libDbOpen();
  return new Promise((res, rej) => {
    const tx = libDbTx(db, [LIB_STORE_FILES, LIB_STORE_META, LIB_STORE_HANDLE], 'readwrite');
    tx.objectStore(LIB_STORE_FILES).clear();
    tx.objectStore(LIB_STORE_META).clear();
    tx.objectStore(LIB_STORE_HANDLE).clear();
    tx.oncomplete = () => { db.close(); res(); };
    tx.onerror = () => { db.close(); rej(tx.error); };
  });
}
async function libDbPutMeta(meta) {
  const db = await libDbOpen();
  return new Promise((res, rej) => {
    const tx = libDbTx(db, [LIB_STORE_META], 'readwrite');
    tx.objectStore(LIB_STORE_META).put(meta, 'meta');
    tx.oncomplete = () => { db.close(); res(); };
    tx.onerror = () => { db.close(); rej(tx.error); };
  });
}
async function libDbGetMeta() {
  const db = await libDbOpen();
  return new Promise((res, rej) => {
    const tx = libDbTx(db, [LIB_STORE_META], 'readonly');
    const req = tx.objectStore(LIB_STORE_META).get('meta');
    req.onsuccess = () => { db.close(); res(req.result || null); };
    req.onerror = () => { db.close(); rej(req.error); };
  });
}
async function libDbPutHandle(handle) {
  const db = await libDbOpen();
  return new Promise((res, rej) => {
    const tx = libDbTx(db, [LIB_STORE_HANDLE], 'readwrite');
    tx.objectStore(LIB_STORE_HANDLE).put(handle, 'root');
    tx.oncomplete = () => { db.close(); res(); };
    tx.onerror = () => { db.close(); rej(tx.error); };
  });
}
async function libDbGetHandle() {
  const db = await libDbOpen();
  return new Promise((res, rej) => {
    const tx = libDbTx(db, [LIB_STORE_HANDLE], 'readonly');
    const req = tx.objectStore(LIB_STORE_HANDLE).get('root');
    req.onsuccess = () => { db.close(); res(req.result || null); };
    req.onerror = () => { db.close(); rej(req.error); };
  });
}

const LIB = {
  files: [],         // { path: 'rules/windows/x.yml', name: 'x.yml', size, content?: string, kind: 'sigma'|'kql'|... }
  rootName: '',
  fsHandle: null,    // FileSystemDirectoryHandle (Chrome/Edge only)
  expanded: new Set(),  // collapsed-by-default; set holds expanded folder paths
  filter: '',
  activePath: null,
};

const LIB_TEXT_EXTS = ['.yml','.yaml','.txt','.json','.json5','.ndjson','.jsonl','.spl','.kql','.xql','.sigma','.md','.toml','.ini','.cfg'];
const LIB_MAX_FILE_BYTES = 256 * 1024;   // 256 KB per file
const LIB_MAX_TOTAL_FILES = 5000;        // safety cap
const LIB_LS_KEY = 'sigma_playground_lib_v1';

function libIsTextFile(name) {
  const lower = name.toLowerCase();
  return LIB_TEXT_EXTS.some(ext => lower.endsWith(ext));
}

function libGuessLang(file) {
  // by extension first
  const ext = file.name.toLowerCase().split('.').pop();
  if (ext === 'sigma' || ext === 'yml' || ext === 'yaml') return 'sigma';
  if (ext === 'spl') return 'spl';
  if (ext === 'kql') return 'kql';
  if (ext === 'xql') return 'xql';
  if (ext === 'lp')  return 'logpoint';
  // by content (if loaded)
  if (file.content) {
    const hint = detectRuleLangHint(file.content);
    if (hint) return hint;
  }
  return null;
}

/* Drag&Drop on the library panel */
const libPanel = $('library');
const libTreeEl = $('library-tree');
['dragenter','dragover'].forEach(ev => libTreeEl.addEventListener(ev, e => {
  e.preventDefault(); e.stopPropagation();
  libTreeEl.classList.add('drop-hover');
}));
['dragleave'].forEach(ev => libTreeEl.addEventListener(ev, e => {
  if (e.target === libTreeEl) libTreeEl.classList.remove('drop-hover');
}));
libTreeEl.addEventListener('drop', async e => {
  e.preventDefault(); e.stopPropagation();
  libTreeEl.classList.remove('drop-hover');
  const items = e.dataTransfer.items ? [...e.dataTransfer.items] : [];
  if (!items.length) return;
  const files = [];
  for (const it of items) {
    if (typeof it.webkitGetAsEntry === 'function') {
      const entry = it.webkitGetAsEntry();
      if (entry) await libCollectFromEntry(entry, '', files);
    } else if (it.kind === 'file') {
      const f = it.getAsFile();
      if (f) files.push({ path: f.name, file: f });
    }
  }
  if (files.length) {
    await libIndexCollectedFiles(files, files[0].path.split('/')[0] || 'dropped');
  }
});

/* Recursively walk a webkitEntry tree (Chrome/Firefox/Safari all support this) */
async function libCollectFromEntry(entry, prefix, out) {
  if (out.length >= LIB_MAX_TOTAL_FILES) return;
  if (entry.isFile) {
    if (!libIsTextFile(entry.name)) return;
    const file = await new Promise((res, rej) => entry.file(res, rej));
    out.push({ path: prefix + entry.name, file });
  } else if (entry.isDirectory) {
    const reader = entry.createReader();
    // readEntries returns batches; loop until empty
    const allEntries = [];
    while (true) {
      const batch = await new Promise((res, rej) => reader.readEntries(res, rej));
      if (!batch.length) break;
      allEntries.push(...batch);
    }
    for (const child of allEntries) {
      await libCollectFromEntry(child, prefix + entry.name + '/', out);
      if (out.length >= LIB_MAX_TOTAL_FILES) return;
    }
  }
}

/* Folder picker button: prefer File System Access API for persistence */
$('lib-pick-folder').onclick = async () => {
  // Chrome/Edge path
  if (window.showDirectoryPicker) {
    try {
      const handle = await window.showDirectoryPicker();
      LIB.fsHandle = handle;
      const files = [];
      await libCollectFromHandle(handle, '', files);
      await libIndexCollectedFiles(files, handle.name);
      return;
    } catch (err) {
      if (err.name === 'AbortError') return;
      console.warn('Directory picker failed, falling back', err);
    }
