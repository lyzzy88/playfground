/* ═══════════════════════════════════════════════════════════
   UI
   ═══════════════════════════════════════════════════════════ */
const $ = id => document.getElementById(id);
const ruleEl = $('rule');
const dataEl = $('data');
const fmtSel = $('data-format');
const fmtTag = $('format-tag');

// example button wiring
document.querySelectorAll('[data-rule]').forEach(b => {
  b.onclick = () => { ruleEl.value = EX[b.dataset.rule]; updateMeta(); };
});
document.querySelectorAll('[data-data]').forEach(b => {
  b.onclick = () => {
    dataEl.value = EX[b.dataset.data];
    const map = { data1:'xml', data2:'xml', data3:'auditd', data4:'laurel', data5:'json', data6:'json' };
    fmtSel.value = map[b.dataset.data] || 'auto';
    fmtTag.textContent = '/ ' + fmtSel.value;
    updateMeta();
  };
});
$('btn-clear-rule').onclick = () => { ruleEl.value = ''; updateMeta(); };
$('btn-clear-data').onclick = () => { dataEl.value = ''; updateFileBadge(null); updateMeta(); };

fmtSel.addEventListener('change', () => { fmtTag.textContent = '/ ' + fmtSel.value; updateMeta(); });

$('btn-upload-rule').onclick = () => $('file-rule').click();
$('file-rule').onchange = async e => {
  const f = e.target.files[0]; if (!f) return;
  ruleEl.value = await f.text(); updateMeta(); e.target.value = '';
};
$('btn-upload-data').onclick = () => $('file-data').click();
$('file-data').onchange = async e => { await loadDataFiles([...e.target.files]); e.target.value = ''; };

async function loadDataFiles(files) {
  if (!files.length) return;
  const parts = await Promise.all(files.map(f => f.text()));
  dataEl.value = parts.join('\n');
  const ext = (files[0].name.split('.').pop() || '').toLowerCase();
  const m = { xml:'xml', evtx:'xml', json:'json', ndjson:'ndjson', jsonl:'ndjson', json5:'json5', log:'auditd', audit:'auditd' };
  if (m[ext]) { fmtSel.value = m[ext]; fmtTag.textContent = '/ ' + m[ext]; }
  else { fmtSel.value = 'auto'; fmtTag.textContent = '/ auto'; }
  const totalKB = files.reduce((s,f) => s + f.size, 0) / 1024;
  updateFileBadge(files.length === 1 ? files[0].name + ' (' + totalKB.toFixed(1) + ' kB)' : files.length + ' files (' + totalKB.toFixed(1) + ' kB)');
  updateMeta();
}

function updateFileBadge(label) {
  const el = $('foot-file');
  el.innerHTML = label ? 'FILE: <b>' + escapeHtml(label) + '</b>' : 'NO FILE LOADED';
}

['dragenter','dragover'].forEach(ev => dataEl.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); dataEl.classList.add('drop-hover'); }));
['dragleave','drop'].forEach(ev => dataEl.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); dataEl.classList.remove('drop-hover'); }));
dataEl.addEventListener('drop', async e => { const files = [...e.dataTransfer.files]; if (files.length) await loadDataFiles(files); });
['dragenter','dragover'].forEach(ev => ruleEl.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); ruleEl.classList.add('drop-hover'); }));
['dragleave','drop'].forEach(ev => ruleEl.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); ruleEl.classList.remove('drop-hover'); }));
ruleEl.addEventListener('drop', async e => { const f = e.dataTransfer.files[0]; if (!f) return; ruleEl.value = await f.text(); updateMeta(); });

// tabs
document.querySelectorAll('.tab').forEach(t => {
  t.onclick = () => {
    document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    $('panel-' + t.dataset.tab).classList.add('active');
    if (t.dataset.tab === 'translate') renderTranslate();
  };
});

function updateMeta() {
  let count = 0;
  try { count = parseEvents(dataEl.value, fmtSel.value).length; } catch { count = '?'; }
  $('meta-events').textContent = 'EVENTS: ' + count;

  try {
    const docs = jsyaml.loadAll(ruleEl.value).filter(d => d && typeof d === 'object');
    const corr = docs.find(d => d.correlation);
    const primary = corr || docs[docs.length - 1];
    const title = primary && primary.title ? primary.title.slice(0, 36) : '—';
    $('meta-rule').textContent = 'RULE: ' + title + (corr ? ' [CORR]' : '');
  } catch { $('meta-rule').textContent = 'RULE: [parse err]'; }

  // re-render translate if active
  const activeTab = document.querySelector('.tab.active');
  if (activeTab && activeTab.dataset.tab === 'translate') renderTranslate();
}
dataEl.addEventListener('input', updateMeta);
ruleEl.addEventListener('input', updateMeta);

// preload
ruleEl.value = EX.rule1;
dataEl.value = EX.data1;
fmtSel.value = 'xml';
fmtTag.textContent = '/ xml';
updateMeta();

// execute
$('execute').onclick = () => {
  const t0 = performance.now();
  $('foot-stat').textContent = 'RUNNING…';
  try {
    const events = parseEvents(dataEl.value, fmtSel.value);
    const res = runRule(ruleEl.value, events);
    const fmt = fmtSel.value === 'auto' ? detectFormat(dataEl.value) : fmtSel.value;
    renderAnalysis(res, events, performance.now() - t0, fmt);
    $('foot-stat').textContent = 'DONE';
    // switch to analysis tab if on translate
    document.querySelector('.tab[data-tab="analysis"]').click();
  } catch (err) {
    renderError(err);
    $('foot-stat').textContent = 'ERROR';
  }
};

function renderError(err) {
  $('results').innerHTML = '<div class="error-box"><strong>⚠ execution error</strong>' + escapeHtml(err.message || String(err)) + '</div>';
  $('rt-time').textContent = 'failed';
}

function escapeHtml(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

function renderAnalysis(res, events, elapsed, fmt) {
  $('rt-time').textContent = elapsed.toFixed(1) + ' ms · ' + fmt;
  if (res.kind === 'detection') renderDetection(res.rule, res.result, events, elapsed, fmt);
  else if (res.kind === 'correlation') renderCorrelation(res.result, events, elapsed, fmt);
}

function renderDetection(rule, results, events, elapsed, fmt) {
  const hits = results.filter(r => r.hit).length;
  const misses = results.length - hits;
  const cond = (rule.detection && rule.detection.condition) || '';
  const title = rule.title || '(untitled)';
  const level = rule.level || 'unknown';

  let html = `
    <div class="summary">
      <div><div class="stat-label">Events</div><div class="stat-val">${results.length}</div></div>
      <div><div class="stat-label">Hits</div><div class="stat-val amber">${hits}</div></div>
      <div><div class="stat-label">Misses</div><div class="stat-val">${misses}</div></div>
      <div><div class="stat-label">Elapsed</div><div class="stat-val">${elapsed.toFixed(1)}<span style="font-size:12px;color:var(--text-faint)">ms</span></div></div>
    </div>
    <div style="margin-bottom:16px;font-size:11px;color:var(--text-dim);letter-spacing:0.1em;">
      <div style="margin-bottom:6px;">▸ <b style="color:var(--text)">${escapeHtml(title)}</b> <span style="color:var(--text-faint);">· level=${escapeHtml(level)} · fmt=${fmt}</span></div>
      <div>▸ condition: <span class="cond">${escapeHtml(cond)}</span></div>
    </div>
  `;
  for (const r of results) {
    const matched = Object.entries(r.selResults).filter(([,v])=>v.ok).map(([k])=>k);
    const label = describeEvent(r.event);
    html += `
      <div class="event-row ${r.hit?'hit':'miss'}">
        <div class="event-head" onclick="this.parentElement.classList.toggle('open')">
          <div class="event-title">
            <span class="badge ${r.hit?'hit':'miss'}">${r.hit?'MATCH':'no match'}</span>
            <span>Event #${r.idx + 1}</span>
            <span class="ellip">${escapeHtml(label)}</span>
          </div>
          <div style="font-size:11.5px;color:var(--text-dim);font-weight:600;letter-spacing:0.05em;">${matched.length ? '<span style="color:var(--amber);">●</span> sel: ' + matched.join(', ') : '<span style="color:var(--text-faint);">—</span>'}</div>
        </div>
        <div class="event-body">${renderEventBody(r)}</div>
      </div>`;
  }
  $('results').innerHTML = html;
  const firstHit = document.querySelector('.event-row.hit');
  if (firstHit) firstHit.classList.add('open');
}

function renderCorrelation(corrRes, events, elapsed, fmt) {
  const groups = corrRes.groups;
  const hits = groups.filter(g => g.hit).length;
  const refRules = corrRes.perRule.map(pr => pr.rule.title || pr.rule.name || '?');
  const baseHits = corrRes.perRule.reduce((a, pr) => a + pr.hits.length, 0);
  const title = corrRes.rule.title || '(untitled)';
  const c = corrRes.rule.correlation;

  let html = `
    <div class="summary">
      <div><div class="stat-label">Groups</div><div class="stat-val">${groups.length}</div></div>
      <div><div class="stat-label">Hits</div><div class="stat-val violet">${hits}</div></div>
      <div><div class="stat-label">Base hits</div><div class="stat-val">${baseHits}</div></div>
      <div><div class="stat-label">Elapsed</div><div class="stat-val">${elapsed.toFixed(1)}<span style="font-size:12px;color:var(--text-faint)">ms</span></div></div>
    </div>
    <div style="margin-bottom:16px;font-size:11px;color:var(--text-dim);letter-spacing:0.1em;">
      <div style="margin-bottom:6px;">▸ <b style="color:var(--text)">${escapeHtml(title)}</b> <span class="corr-chip">${escapeHtml(c.type)}</span></div>
      <div>▸ rules: ${refRules.map(escapeHtml).join(' → ')}</div>
      <div>▸ group-by: ${(c['group-by']||[]).map(escapeHtml).join(', ')} · timespan: ${escapeHtml(String(c.timespan||'—'))} · condition: ${escapeHtml(JSON.stringify(c.condition||{}))}</div>
    </div>
  `;
  if (!groups.length) {
    html += '<div style="color:var(--text-faint);font-size:11px;">No matching base events — no groups formed.</div>';
  }
  groups.sort((a,b) => (b.hit?1:0)-(a.hit?1:0) || b.count - a.count).forEach(g => {
    const groupKey = g.groupKey || '(∅)';
    const details = g.valueSet ? ' · values: ' + g.valueSet.slice(0, 8).join(', ') + (g.valueSet.length > 8 ? '…' : '') : '';
    html += `
      <div class="group-row ${g.hit?'hit':'miss'}">
        <div class="group-head" onclick="this.parentElement.classList.toggle('open')">
          <div class="group-key">
            <span class="badge ${g.hit?'corr':'miss'}">${g.hit?'TRIGGER':'below'}</span>
            <span><b style="color:var(--text)">${escapeHtml(groupKey)}</b></span>
          </div>
          <div class="group-count ${g.hit?'ok':'no'}">${g.count}</div>
        </div>
        <div class="group-body">
          <div class="sub">Group: ${(g.groupFields||[]).map(escapeHtml).join(', ') || '(ungrouped)'}${details}</div>
          <div class="sub">Events (${g.eventIdxs.length}):</div>
          <ul>${g.eventIdxs.map(i => '<li>#' + (i+1) + ' · ' + escapeHtml(describeEvent(events[i])) + '</li>').join('')}</ul>
        </div>
      </div>`;
  });
  $('results').innerHTML = html;
  const firstHit = document.querySelector('.group-row.hit');
  if (firstHit) firstHit.classList.add('open');
}

function describeEvent(e) {
  if (!e) return '';
  if (e.EventID) return 'EventID=' + e.EventID + (e.Computer ? ' @ ' + e.Computer : '') + (e.TargetUserName ? ' · ' + e.TargetUserName : '');
  if (e.exe) return e.exe + (e.comm ? ' (' + e.comm + ')' : '');
  if (e.type) return 'auditd ' + e.type + (e._serial ? ' #' + e._serial : '');
  const k = Object.keys(e).find(x => !x.startsWith('_'));
  return k ? (k + '=' + String(e[k]).slice(0, 80)) : '';
}

function renderEventBody(r) {
  const matchedFields = {};
  for (const [,sr] of Object.entries(r.selResults)) if (sr.ok) for (const m of sr.matches) matchedFields[m.field] = true;
  const rows = [];
  for (const k of Object.keys(r.event).filter(x => !x.startsWith('_')).sort()) {
    const v = r.event[k];
    if (v === undefined || v === null) continue;
    const isMatch = k in matchedFields;
    rows.push('<div class="k">' + escapeHtml(k) + '</div><div class="v ' + (isMatch?'match':'') + '">' + escapeHtml(v) + '</div>');
  }
  const selHtml = Object.entries(r.selResults).map(([k, v]) =>
    '<div style="margin-top:4px;"><span style="color:' + (v.ok?'var(--amber)':'var(--text-faint)') + ';">' + (v.ok?'✓':'✗') + ' ' + escapeHtml(k) + '</span></div>'
  ).join('');
  return '<div class="kv">' + rows.join('') + '</div>' +
    '<div style="margin-top:12px;padding-top:10px;border-top:1px dashed var(--border);font-size:10.5px;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-faint);">Selections</div>' + selHtml;
}

/* ═════════ TRANSLATE TAB ═════════ */
function renderTranslate() {
  const out = $('translate-out');
  let graph;
  try { graph = parseRuleGraph(ruleEl.value); }
  catch (err) {
    out.innerHTML = '<div class="empty"><div class="msg">parse error</div><div class="hint" style="color:var(--red)">' + escapeHtml(err.message) + '</div></div>';
    return;
  }
  const primary = graph.docs[graph.docs.length - 1];
  const isCorr = !!primary.correlation;
  const title = primary.title || '(untitled)';

  let html = `
    <div class="translate-head">
      <div>▸ <b>${escapeHtml(title)}</b> ${isCorr ? '<span class="corr-chip">' + escapeHtml(primary.correlation.type||'corr') + '</span>' : ''}</div>
      <div class="meta">
        ${graph.detections.length} detection rule${graph.detections.length!==1?'s':''} · ${graph.correlations.length} correlation${graph.correlations.length!==1?'s':''}
      </div>
    </div>
  `;

  for (const b of BACKENDS) {
    let query, err;
    try {
      if (isCorr) query = b.corr(primary, graph);
      else query = b.det(primary);
    } catch (e) { err = e.message; }

    html += `
      <div class="backend-card">
        <div class="backend-head">
          <div class="backend-name"><span class="sigil">▸</span>${escapeHtml(b.name)}<span class="fmt">· ${escapeHtml(b.fmt)}</span></div>
          <button class="backend-copy" data-backend="${b.id}">COPY</button>
        </div>
        <pre class="backend-query ${err?'error':''}" id="q-${b.id}">${escapeHtml(err || query || '(empty)')}</pre>
        <div class="backend-notes"><b>NOTE</b> · ${escapeHtml(b.note)}</div>
      </div>`;
  }

  out.innerHTML = html;
  // wire copy buttons
  document.querySelectorAll('.backend-copy').forEach(btn => {
    btn.onclick = () => {
      const id = btn.dataset.backend;
      const q = document.getElementById('q-' + id).textContent;
      navigator.clipboard.writeText(q).then(() => {
        const orig = btn.textContent;
        btn.textContent = '✓ COPIED';
        btn.classList.add('copied');
        setTimeout(() => { btn.textContent = orig; btn.classList.remove('copied'); }, 1200);
      });
    };
  });
}

// keyboard
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); $('execute').click(); }
  if ((e.ctrlKey || e.metaKey) && e.key === 't') { e.preventDefault(); document.querySelector('.tab[data-tab="translate"]').click(); }
});

</script>
