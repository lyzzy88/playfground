/* ═════════ CORRELATION CONVERTERS ═════════ */
function corrOpSigma(cond) {
  if ('gte' in cond) return { op: '>=', n: cond.gte };
  if ('gt'  in cond) return { op: '>',  n: cond.gt };
  if ('lte' in cond) return { op: '<=', n: cond.lte };
  if ('lt'  in cond) return { op: '<',  n: cond.lt };
  if ('eq'  in cond) return { op: '==', n: cond.eq };
  return { op: '>=', n: 1 };
}
function corrToLucene(corr, graph) {
  const ref = graph.byName[corr.correlation.rules[0]];
  if (!ref) return '# unresolved rule: ' + corr.correlation.rules[0];
  const base = toLucene(ref);
  return '# base query (index-time)\n' + base + '\n# correlation: cannot be expressed in Lucene alone — use ES|QL / Kibana watcher:\n# | STATS count = COUNT(*) BY ' + (corr.correlation['group-by'] || []).join(', ') + '\n# | WHERE count ' + corrOpSigma(corr.correlation.condition).op + ' ' + corrOpSigma(corr.correlation.condition).n;
}
function corrToSPL(corr, graph) {
  const c = corr.correlation;
  const ref = graph.byName[c.rules[0]];
  if (!ref) return '# unresolved rule';
  const base = toSPL(ref);
  const { op, n } = corrOpSigma(c.condition);
  const ts = c.timespan ? ('earliest=-' + c.timespan + ' ') : '';
  if (c.type === 'value_count') {
    return ts + base + '\n| stats dc(' + c.field + ') as cnt by ' + (c['group-by']||[]).join(', ') +
           '\n| where cnt ' + op + ' ' + n;
  }
  return ts + base + '\n| stats count as cnt by ' + (c['group-by']||[]).join(', ') +
         '\n| where cnt ' + op + ' ' + n;
}
function corrToKQL(corr, graph) {
  const c = corr.correlation;
  const ref = graph.byName[c.rules[0]];
  if (!ref) return '// unresolved rule';
  const base = toKQL(ref);
  const { op, n } = corrOpSigma(c.condition);
  const span = c.timespan || '1h';
  const binExpr = 'bin(TimeGenerated, ' + span + ')';
  if (c.type === 'value_count') {
    return base + '\n| summarize cnt = dcount(' + c.field + ') by ' + (c['group-by']||[]).concat([binExpr]).join(', ') +
           '\n| where cnt ' + op + ' ' + n;
  }
  return base + '\n| summarize cnt = count() by ' + (c['group-by']||[]).concat([binExpr]).join(', ') +
         '\n| where cnt ' + op + ' ' + n;
}
function corrToXQL(corr, graph) {
  const c = corr.correlation;
  const ref = graph.byName[c.rules[0]];
  if (!ref) return '// unresolved rule';
  const base = toXQL(ref);
  const { op, n } = corrOpSigma(c.condition);
  if (c.type === 'value_count') {
    return base + '\n| comp count_distinct(' + c.field + ') as cnt by ' + (c['group-by']||[]).join(', ') +
           '\n| filter cnt ' + op + ' ' + n;
  }
  return base + '\n| comp count() as cnt by ' + (c['group-by']||[]).join(', ') +
         '\n| filter cnt ' + op + ' ' + n;
}
function corrToLogpoint(corr, graph) {
  const c = corr.correlation;
  const ref = graph.byName[c.rules[0]];
  if (!ref) return '# unresolved rule';
  const base = toLogpoint(ref);
  const { op, n } = corrOpSigma(c.condition);
  if (c.type === 'value_count') {
    return base + '\n| chart distinct_count(' + c.field + ') as cnt by ' + (c['group-by']||[]).join(', ') +
